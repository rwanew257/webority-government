@page
@model Webority.Web.GovIndia.Pages.SectorsModel
@{
    ViewData["Title"] = "Sectors";
    ViewData["Description"] = "Sectors served by Webority Government across Union ministries, State Governments, urban local bodies and PSUs.";
    ViewData["ActiveNav"] = "sectors";
    ViewData["BodyClass"] = "sectors-page";
}
<section class="svc-hero">
    <div class="container">
      <div class="svc-hero-content">
        <h1>Sectors We Serve</h1>
        <p>Delivering tailored digital solutions across India&rsquo;s key government and enterprise sectors &mdash; with verified deployments and sector-specific domain expertise.</p>
      </div>
    </div>
  </section>

  <!-- Stats Row -->
  <section class="sect">
    <div class="container">
      <div class="stats-v2 sectors-stats-cards">
        <div>
          <span class="sectors-stat-ic" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          </span>
          <span class="num">10<span class="plus">+</span></span>
          <span class="lbl">Years of Serving</span>
        </div>
        <div>
          <span class="sectors-stat-ic" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 12l9 4 9-4"/><path d="M3 17l9 4 9-4"/></svg>
          </span>
          <span class="num">500<span class="plus">+</span></span>
          <span class="lbl">Projects Delivered</span>
        </div>
        <div>
          <span class="sectors-stat-ic" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21h16"/><path d="M5 21V10M19 21V10M9 21V10M15 21V10"/><path d="M12 3L4 8h16z"/></svg>
          </span>
          <span class="num">10<span class="plus">+</span></span>
          <span class="lbl">Ministries Served</span>
        </div>
        <div>
          <span class="sectors-stat-ic" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"/><circle cx="17" cy="9" r="2.6"/><path d="M3 20c0-3.3 2.7-5.5 6-5.5s6 2.2 6 5.5"/><path d="M15 20c0-2.6 1.6-4.6 4-4.6s2 1 2 1"/></svg>
          </span>
          <span class="num">80<span class="plus">+</span></span>
          <span class="lbl">Professionals</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Sector cards — each links to its own detail page -->
  <section class="sect sect-soft">
    <div class="container">
      <div class="sect-head sect-head--centered">
        <span class="eyebrow">Government &amp; Public Sector</span>
        <h2>Explore Our Sectors</h2>
        <p>Choose a sector to see the capabilities we build, the reference projects we have delivered, and the partners we work with.</p>
      </div>

      <div class="sector-cards">
        <a class="sector-card" asp-page="/Sectors/EnergyEnvironment">
          <span class="sector-card-ic" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 3L6 18h9l-1 11 12-16h-9z"/>
            </svg>
          </span>
          <h3 class="sector-card-title">Energy &amp; Environment</h3>
          <p class="sector-card-sub">Compliance platforms for energy efficiency and environmental governance &mdash; from appliance rating to sustainability tracking.</p>
          <span class="sector-card-cta">Explore sector
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
          </span>
        </a>

        <a class="sector-card" asp-page="/Sectors/HealthWelfare">
          <span class="sector-card-ic" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 27S5 20 5 12a6 6 0 0 1 11-3 6 6 0 0 1 11 3c0 8-11 15-11 15z"/>
              <path d="M10 15h3l2-4 2 8 2-4h3"/>
            </svg>
          </span>
          <h3 class="sector-card-title">Health &amp; Welfare</h3>
          <p class="sector-card-sub">DPDP-compliant, offline-first health infrastructure for government hospitals and tribal field conditions.</p>
          <span class="sector-card-cta">Explore sector
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
          </span>
        </a>

        <a class="sector-card" asp-page="/Sectors/DefenceSecurity">
          <span class="sector-card-ic" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 3l11 4v8c0 7-4.6 12.4-11 14.5C9.6 27.4 5 22 5 15V7z"/>
              <path d="M11 15l3.5 3.5L22 11"/>
            </svg>
          </span>
          <h3 class="sector-card-title">Defence &amp; Security</h3>
          <p class="sector-card-sub">VAPT-cleared, ISO 27001:2022 secure systems for defence forces, paramilitary and internal security.</p>
          <span class="sector-card-cta">Explore sector
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
          </span>
        </a>

        <a class="sector-card" asp-page="/Sectors/Parliament">
          <span class="sector-card-ic" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 4L4 11h24z"/>
              <path d="M3 11h26"/>
              <path d="M6 11v14M11 11v14M16 11v14M21 11v14M26 11v14"/>
              <path d="M4 28h24"/>
            </svg>
          </span>
          <h3 class="sector-card-title">Parliament &amp; Legislature</h3>
          <p class="sector-card-sub">Secure communication and collaboration infrastructure for India&rsquo;s parliamentary institutions.</p>
          <span class="sector-card-cta">Explore sector
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
          </span>
        </a>

        @* WG: Finance, PSUs & Fintech sector temporarily hidden *@
        @* <a class="sector-card" asp-page="/Sectors/FinancePsus"> ... Finance, PSUs & Fintech ... </a> *@

        <a class="sector-card" asp-page="/Sectors/QualityStandards">
          <span class="sector-card-ic" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 4l2.5 3 4-0.5 0.5 4 3.5 2-1.5 3.5 1.5 3.5-3.5 2-0.5 4-4-0.5L16 28l-2.5-3-4 0.5-0.5-4-3.5-2 1.5-3.5L5.5 12.5l3.5-2 0.5-4 4 0.5z"/>
              <path d="M11 16l3 3 6-7"/>
            </svg>
          </span>
          <h3 class="sector-card-title">Quality &amp; Standards</h3>
          <p class="sector-card-sub">Certification, accreditation and quality-compliance systems for regulatory and standards bodies.</p>
          <span class="sector-card-cta">Explore sector
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
          </span>
        </a>

        <a class="sector-card" asp-page="/Sectors/EducationPublishing">
          <span class="sector-card-ic" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 9C13 6 8 6 4 7v18c4-1 9-1 12 2 3-3 8-3 12-2V7c-4-1-9-1-12 2z"/>
              <path d="M16 9v22"/>
            </svg>
          </span>
          <h3 class="sector-card-title">Education &amp; Publishing</h3>
          <p class="sector-card-sub">Digital library platforms, e-book distribution and publishing workflow automation.</p>
          <span class="sector-card-cta">Explore sector
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
          </span>
        </a>

        <a class="sector-card" asp-page="/Sectors/SmartCitiesUrban">
          <span class="sector-card-ic" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="14" width="9" height="14"/>
              <rect x="16" y="6" width="11" height="22"/>
              <path d="M7 18h3M7 22h3M19 11h5M19 15h5M19 19h5M19 23h5"/>
              <path d="M4 28h24"/>
            </svg>
          </span>
          <h3 class="sector-card-title">Smart Cities, Urban &amp; NGOs</h3>
          <p class="sector-card-sub">Smart-city platforms, urban-governance systems and technology for mission-driven organisations.</p>
          <span class="sector-card-cta">Explore sector
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>
