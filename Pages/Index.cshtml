            <article class="ai-card">
              <span class="ai-card-ic" aria-hidden="true">
                <i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/linear/search-status.svg');"></i>
              </span>
