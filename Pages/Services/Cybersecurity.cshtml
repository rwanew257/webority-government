@page
@model Webority.Web.GovIndia.Pages.Services.CybersecurityModel
@{
    ViewData["Title"] = "VAPT & Cybersecurity for Government India";
    ViewData["Description"] = "Comprehensive cybersecurity for Indian government — VAPT, ISO 27001 implementation, and CERT-In aligned incident response for ministries, paramilitary forces, and PSUs.";
    ViewData["ActiveNav"] = "services";
    ViewData["BodyClass"] = "services-page";
}
<!-- Hero -->
  <section class="egov-hero">
    <div class="container">
      <div class="egov-hero-content">
        <h1>VAPT &amp; Cybersecurity for Government India</h1>
        <p class="egov-hero-lead">Comprehensive security services — from VAPT assessments to ISO 27001 implementation and CERT-In aligned incident response — for Central Government ministries, paramilitary forces, and PSUs.</p>
        <p class="svc-hero-standards">CERT-In Aligned   ·   ISO 27001:2017 Certified   ·   DPDP Act Compliant</p>
      </div>
    </div>
  </section>

  <!-- What We Deliver -->
  <section class="egov-band">
    <div class="container">
      <div class="egov-band-grid">
        <div>
          <span class="egov-eyebrow">What We Deliver</span>
          <h2 class="egov-h2">Securing India’s Government Digital Infrastructure</h2>
          <p class="copy">We provide comprehensive cybersecurity services designed for government environments — from VAPT assessments to full ISO 27001 implementation support and CERT-In aligned incident response planning.</p>
          <p class="copy">Our team has conducted security assessments for paramilitary forces under the Ministry of Home Affairs — among the most sensitive government environments in India. Every engagement is conducted with the highest levels of confidentiality and GoI security compliance.</p>
          <ul class="egov-checklist">
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Vulnerability Assessment &amp; Penetration Testing</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Web Application Security Audits</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Network Security Assessment</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> ISO 27001:2017 Implementation</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> CERT-In Compliance Gap Analysis</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Security Architecture Design</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Cybersecurity Policy &amp; SOP Documentation</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Third-Party Vendor Security Assessment</li>
          </ul>
          <div class="egov-btn-row">
            <a asp-page="/Contact" class="btn btn-primary btn-glow btn-md"><span class="btn-glow-label">Discuss Your Requirements</span><svg class="btn-glow-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg></a>
            <a asp-page="/CaseStudies" class="btn btn-outline btn-md">View Projects</a>
          </div>
        </div>
        <div class="egov-ref-panel">
          <span class="egov-eyebrow">Reference Projects</span>
          <!-- TODO-WG: each public-sector reference below must have approved public listing before publishing. -->
          <ul class="egov-ref-list">
            <li class="egov-ref-item">
              <span class="egov-ref-logo"><img src="/images/logos/gov/SSB 64PX LOGO.svg" alt="Sashastra Seema Bal (SSB)" loading="lazy" /></span>
              <span>
                <p class="egov-ref-name">Sashastra Seema Bal (SSB)</p>
                <p class="egov-ref-proj">Ministry of Home Affairs · Comprehensive VAPT · CERT-In compliant</p>
              </span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="egov-build">
    <div class="container">
      <div class="egov-build-head">
        <span class="egov-eyebrow">Capabilities</span>
        <h2 class="egov-h2">What Our Cybersecurity Practice Delivers</h2>
        <p>CERT-In aligned security capabilities across every government engagement we handle.</p>
      </div>
      <div class="egov-build-grid">
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l8 4v6c0 5-3.5 8-8 10-4.5-2-8-5-8-10V6z"/><path d="m9 12 2 2 4-4"/></svg></span>
          <h3>VAPT — Web, API &amp; Network</h3>
          <p>Comprehensive vulnerability assessment and penetration testing across web applications, APIs, mobile apps, and network infrastructure.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M8.21 13.89 7 22l5-3 5 3-1.21-8.11"/></svg></span>
          <h3>ISO 27001:2017 ISMS Implementation</h3>
          <p>Full information security management system design, gap analysis, policy documentation, and certification support.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg></span>
          <h3>Secure Code Review &amp; SAST</h3>
          <p>Static application security testing, OWASP Top 10 remediation, and threat modelling integrated into the development lifecycle.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
          <h3>Data Protection &amp; DPDP Act 2023</h3>
          <p>Privacy impact assessments, data flow mapping, consent management architecture, and compliance documentation for all citizen data platforms.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg></span>
          <h3>CERT-In Audit Reports</h3>
          <p>Formal security assessment reports structured as government audit deliverables — accepted by ministry IT divisions and auditors.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg></span>
          <h3>Incident Response Planning</h3>
          <p>Security incident playbooks, escalation matrices, and SOC integration support for government platforms handling citizen data.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="egov-certs">
    <div class="container">
      <div class="sect-head">
        <span class="egov-eyebrow">Government &amp; Public Sector</span>
        <h2 class="egov-h2">Certifications</h2>
      </div>
      <!-- TODO-WG: confirm the exact list of held certifications; replace any seal below with the real certificate. -->
      <div class="cert-seals-row">
        <div class="cert-seal-card"><div class="cert-seal-img-wrap"><img class="cert-seal-img" src="/images/credentials/cmmi-l5.png" alt="CMMI Level 5 certified" loading="lazy" /></div><div class="cert-seal-card-name">CMMI Level 5</div></div>
        <div class="cert-seal-card"><div class="cert-seal-img-wrap"><img class="cert-seal-img" src="/images/credentials/iso-27001-2022.png" alt="ISO 27001:2022 certified" loading="lazy" /></div><div class="cert-seal-card-name">Information Security</div></div>
        <div class="cert-seal-card"><div class="cert-seal-img-wrap"><img class="cert-seal-img" src="/images/credentials/iso-9001-2015.png" alt="ISO 9001:2015 certified" loading="lazy" /></div><div class="cert-seal-card-name">Quality Management</div></div>
        <div class="cert-seal-card"><div class="cert-seal-img-wrap"><img class="cert-seal-img" src="/images/credentials/iso-20000-2018.png" alt="ISO 20000:2018 certified" loading="lazy" /></div><div class="cert-seal-card-name">IT Service Management</div></div>
        <div class="cert-seal-card"><div class="cert-seal-img-wrap"><img class="cert-seal-img" src="/images/logos/gov/Start up logo.svg" alt="DPIIT — Startup India recognised" loading="lazy" onerror="this.style.display='none'; this.parentNode.classList.add('reg-card-logo--fallback'); this.parentNode.setAttribute('aria-hidden','true'); this.parentNode.textContent='DPIIT';" /></div><div class="cert-seal-card-name">Startup India / DPIIT</div></div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="egov-faq">
    <div class="container">
      <div class="sect-head">

        <h2 class="egov-h2">Frequently Asked Questions</h2>
      </div>
      <!-- TODO-WG: verify each Q&A pairing and all compliance/client claims (ISO version, certifications, named bodies) before publishing. -->
      <div class="faq-wrap">
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">What does a CERT-In aligned VAPT from Webority include?</button>
          <div class="faq-a"><p>VAPT (Vulnerability Assessment and Penetration Testing) for government is a structured cybersecurity assessment that identifies and validates security vulnerabilities in government digital infrastructure — web portals, applications, networks, and databases. Government VAPT must be aligned with CERT-In security guidelines and NIC information security policy. Reports are delivered with a formal remediation roadmap suitable for government audit documentation. Webority has conducted VAPT for organisations including Sashastra Seema Bal under the Ministry of Home Affairs — among the most sensitive security environments in India.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">How quickly can Webority mobilise for an urgent government security assessment?</button>
          <div class="faq-a"><p>Webority Technologies holds ISO 27001:2017 certification for its Information Security Management System (ISMS). This certification governs how the organisation handles all government client data throughout the project lifecycle — covering data classification, access control, incident management, and supplier security. The same ISO 27001:2017 standard is applied when helping government clients achieve their own ISMS certification.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Does Webority provide post-VAPT remediation support and clearance reports?</button>
          <div class="faq-a"><p>All cybersecurity engagements are designed around the DPDP Act 2023 framework — ensuring data minimisation during security testing, secure handling of vulnerability data, and breach notification protocol documentation as a standard deliverable. Our VAPT methodology includes a DPDP Act 2023 compliance gap analysis as a component of every government cybersecurity assessment. All testing is conducted on isolated environments with NDA and government-grade confidentiality protocols in place.</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA strip -->
  <section class="egov-cta">
    <div class="container">
      <h2>Need a CERT-In aligned security assessment?</h2>
      <p>Tell us about the system, its data classification, and your audit timeline — we’ll scope the engagement under full confidentiality.</p>
      <a asp-page="/Contact" class="btn btn-primary btn-glow btn-md"><span class="btn-glow-label">Contact Us</span><svg class="btn-glow-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg></a>
    </div>
  </section>

@section HeadStyles {
    <link rel="stylesheet" href="~/css/pages/service-security.css" />
}
