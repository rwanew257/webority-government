@page
@model Webority.Web.GovIndia.Pages.Services.EGovernanceModel
@{
    ViewData["Title"] = "e-Governance Software for Public Sector India";
    ViewData["Description"] = "Bespoke e-Governance software for Central and State Government departments, PSUs and autonomous bodies in India — NIC-compatible, GIGW 3.0 / WCAG 2.1 AA, DPDP Act 2023 aligned and MeghRaj-ready.";
    ViewData["ActiveNav"] = "services";
    ViewData["BodyClass"] = "services-page";
}
<!-- Hero -->
  <section class="egov-hero">
    <div class="container">
      <div class="egov-hero-content">
        <h1>e-Governance Software for Public Sector India</h1>
        <p class="egov-hero-lead">Bespoke digital platforms for Central and State Government departments, PSUs, and autonomous bodies &mdash; built to NIC standards, GIGW compliance, and government data security requirements.</p>
      </div>
    </div>
  </section>

  <!-- Intro band: Government Software Built for Real Conditions -->
  <section class="egov-band">
    <div class="container">
      <div class="egov-band-grid">
        <div>
          <span class="egov-eyebrow">What We Deliver</span>
          <h2 class="egov-h2">Government Software Built for Real Conditions</h2>
          <p class="copy">We design and develop bespoke software platforms for Central and State Government departments, PSUs, and autonomous bodies. Every platform is built to NIC technical standards, GIGW accessibility guidelines, and government data security requirements.</p>
          <p class="copy">Government software is not commercial software with a new coat of paint. It requires multi-stakeholder approval workflows, audit trails, role-based access for hundreds of officers, vernacular language support, and low-connectivity operation. We have built all of these &mdash; for Parliament of India, BEE, and QCI.</p>
          <ul class="egov-checklist">
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Citizen Service Portals</li>
            <!-- TODO-WG: "State management mastery" reads as a placeholder in the source PDF; confirm the intended capability label. -->
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> State management mastery</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Business Licensing Platforms</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> National Programme Monitoring</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Compliance &amp; Inspection Management</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> eOffice Integration &amp; Document Mgmt.</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Ministry Websites (GIGW 3.0)</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Grievance Redressal &amp; RTI Portals</li>
          </ul>
          <div class="egov-btn-row">
            <a asp-page="/Contact" class="btn btn-primary btn-glow btn-md"><span class="btn-glow-label">Discuss Your Requirements</span><svg class="btn-glow-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg></a>
            <a asp-page="/CaseStudies" class="btn btn-outline btn-md">View Projects</a>
          </div>
        </div>
        <div class="egov-ref-panel">
          <span class="egov-eyebrow">Reference Projects</span>
          <!-- TODO-WG: each public-sector reference below must have approved public listing before publishing. -->
          <ul class="egov-ref-list">
            <li class="egov-ref-item">
              <span class="egov-ref-logo"><img src="/images/logos/gov/parliament-cafeteria.svg" alt="Parliament of India" loading="lazy" /></span>
              <span>
                <p class="egov-ref-name">Parliament of India</p>
                <p class="egov-ref-proj">Online Food Ordering System</p>
              </span>
            </li>
            <li class="egov-ref-item">
              <span class="egov-ref-logo"><img src="/images/logos/gov/BEE logo.svg" alt="Bureau of Energy Efficiency" loading="lazy" /></span>
              <span>
                <p class="egov-ref-name">Bureau of Energy Efficiency</p>
                <p class="egov-ref-proj">Market Surveillance &amp; Compliance Platform</p>
              </span>
            </li>
            <li class="egov-ref-item">
              <span class="egov-ref-logo"><img src="/images/logos/gov/Case Study Detail logo QCI .svg" alt="Quality Council of India" loading="lazy" /></span>
              <span>
                <p class="egov-ref-name">Quality Council of India</p>
                <p class="egov-ref-proj">SAMAR Certification Platform</p>
              </span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Build for Government -->
  <section class="egov-build">
    <div class="container">
      <div class="egov-build-head">
        <span class="egov-eyebrow">Capabilities</span>
        <h2 class="egov-h2">What We Build for Government</h2>
        <p>Every e-Governance platform we ship carries the same foundations &mdash; security, accessibility, interoperability and resilience &mdash; baked in from day one, not retrofitted before audit.</p>
      </div>
      <div class="egov-build-grid">
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/linear/user-tick.svg');"></i></span>
          <h3>Role-Based Access &amp; Audit Trails</h3>
          <p>Granular, role-scoped permissions with full audit logging on every action &mdash; so every approval, edit and submission is traceable to a user and a timestamp.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/linear/global.svg');"></i></span>
          <h3>Multilingual &amp; GIGW 3.0 Compliant</h3>
          <p>Built against GIGW 3.0 and WCAG 2.1 AA from day one, with multilingual interfaces so citizens are served in their own language across devices.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/linear/wifi.svg');"></i></span>
          <h3>Offline-First &amp; Low-Bandwidth</h3>
          <p>Field-ready applications that capture and sync data on patchy or absent connectivity &mdash; designed for low-bandwidth Bharat, not just metro broadband.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/linear/layer.svg');"></i></span>
          <h3>India Stack Integration</h3>
          <p>Aadhaar e-KYC, DigiLocker and UPI integrated against the published India Stack APIs under the relevant agreements and MeitY security guidelines.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/linear/code-1.svg');"></i></span>
          <h3>NIC &amp; API Compatible</h3>
          <p>Open-standard, API-first architecture (OpenAPI, OAuth 2.0) that deploys on NIC infrastructure and interoperates with departmental ERPs &mdash; no proprietary lock-in.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/linear/chart-2.svg');"></i></span>
          <h3>Real-Time Reporting Dashboards</h3>
          <p>Live programme-monitoring dashboards that give leadership a real-time view of operations across every unit, district or scheme.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="egov-certs">
    <div class="container">
      <div class="sect-head">
        <span class="egov-eyebrow">Government &amp; Public Sector</span>
        <h2 class="egov-h2">Certifications</h2>
      </div>
      <!-- TODO-WG: confirm the exact list of held certifications; replace any seal below with the real certificate. -->
      <div class="cert-seals-row">
        <div class="cert-seal-card">
          <div class="cert-seal-img-wrap">
            <img class="cert-seal-img" src="/images/credentials/cmmi-l5.png" alt="CMMI Level 5 certified" loading="lazy" />
          </div>
          <div class="cert-seal-card-name">CMMI Level 5</div>
        </div>
        <div class="cert-seal-card">
          <div class="cert-seal-img-wrap">
            <img class="cert-seal-img" src="/images/credentials/iso-27001-2022.png" alt="ISO 27001:2022 certified" loading="lazy" />
          </div>
          <div class="cert-seal-card-name">Information Security</div>
        </div>
        <div class="cert-seal-card">
          <div class="cert-seal-img-wrap">
            <img class="cert-seal-img" src="/images/credentials/iso-9001-2015.png" alt="ISO 9001:2015 certified" loading="lazy" />
          </div>
          <div class="cert-seal-card-name">Quality Management</div>
        </div>
        <div class="cert-seal-card">
          <div class="cert-seal-img-wrap">
            <img class="cert-seal-img" src="/images/credentials/iso-20000-2018.png" alt="ISO 20000:2018 certified" loading="lazy" />
          </div>
          <div class="cert-seal-card-name">IT Service Management</div>
        </div>
        <div class="cert-seal-card">
          <div class="cert-seal-img-wrap">
            <img class="cert-seal-img" src="/images/logos/gov/Start up logo.svg" alt="DPIIT — Startup India recognised" loading="lazy" />
          </div>
          <div class="cert-seal-card-name">Startup India / DPIIT</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="egov-faq">
    <div class="container">
      <div class="sect-head">

        <h2 class="egov-h2">Frequently Asked Questions</h2>
      </div>
      <div class="faq-wrap">
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Can Webority&rsquo;s e-Governance platforms be deployed on NIC Data Centres and MeghRaj GI Cloud?</button>
          <div class="faq-a"><p>Yes &mdash; our cloud and managed-infrastructure practice deploys regularly on NIC Data Centres and MeghRaj GI Cloud, in addition to empanelled sovereign and hyperscaler clouds. We tailor the deployment topology to the data classification and the issuing department&rsquo;s policy.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Does Webority&rsquo;s e-governance software comply with GIGW 3.0 and WCAG 2.1 AA?</button>
          <div class="faq-a"><p>We design against GIGW 3.0 and WCAG 2.1 AA from day one &mdash; not as a remediation exercise. Conformance is verified through internal review and, where required, an independent audit. Discrepancies are tracked to closure as part of release governance.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">How does Webority handle Aadhaar, DigiLocker and UPI integration in government platforms?</button>
          <div class="faq-a"><p>We work with the published India Stack APIs under the relevant agreements (AUA / KUA for Aadhaar; DigiLocker partner credentials; NPCI / acquiring-bank arrangements for UPI). All integrations follow MeitY security guidelines and are reviewed for data-minimisation before go-live.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Does Webority handle DPDP Act 2023 compliance for government data?</button>
          <div class="faq-a"><p>Yes. Our delivery process applies data-classification at design time, encrypts at rest and in transit, restricts access by role with audit logging, and aligns processing with the Digital Personal Data Protection Act 2023.</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA strip -->
  <section class="egov-cta">
    <div class="container">
      <h2>Building an e-Governance platform?</h2>
      <p>Tell us about your department, the citizens you serve and the standards you must meet &mdash; we&rsquo;ll map the delivery.</p>
      <a asp-page="/Contact" class="btn btn-primary btn-glow btn-md"><span class="btn-glow-label">Contact Us</span><svg class="btn-glow-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg></a>
    </div>
  </section>

@section HeadStyles {
    <link rel="stylesheet" href="~/css/pages/service-egov.css" />
}
