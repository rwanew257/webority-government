@page
@model Webority.Web.GovIndia.Pages.Services.ConsultingModel
@{
    ViewData["Title"] = "Digital Transformation Consulting for Government India";
    ViewData["Description"] = "Independent, vendor-neutral technology advisory for Indian government — e-governance roadmaps, GFR 2017-aligned RFP writing, vendor evaluation, and PMU support.";
    ViewData["ActiveNav"] = "services";
    ViewData["BodyClass"] = "services-page";
}
<!-- Hero -->
  <section class="egov-hero">
    <div class="container">
      <div class="egov-hero-content">
        <h1>Digital Transformation Consulting for Government India</h1>
        <p class="egov-hero-lead">Independent technology advisory for government departments — translating policy mandates and Digital India objectives into deployable, procurable technical roadmaps. Strategy first. Technology second.</p>
        <p class="svc-hero-standards">Pre-Bid Advisory Free   ·   Digital India Alignment   ·   GFR 2017 Aligned</p>
      </div>
    </div>
  </section>

  <!-- What We Deliver -->
  <section class="egov-band">
    <div class="container">
      <div class="egov-band-grid">
        <div>
          <span class="egov-eyebrow">What We Deliver</span>
          <h2 class="egov-h2">Advisory Grounded in Real Government Delivery</h2>
          <p class="copy">We provide independent technology advisory for Central and State Government departments, PSUs, and autonomous bodies. Every engagement translates policy mandates and Digital India objectives into deployable, procurable technical roadmaps, aligned with GFR 2017 procurement rules and GeM processes.</p>
          <p class="copy">Most consulting firms write strategy decks. We write RFPs that survive procurement scrutiny and roadmaps that survive implementation — because the advice is grounded in delivering production systems for Parliament of India, BEE, and QCI, not frameworks built for boardrooms.</p>
          <ul class="egov-checklist">
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> e-Governance Strategy &amp; Roadmaps</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> RFP &amp; Tender Specification Writing</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Independent Vendor Evaluation</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> PMU Setup &amp; Programme Governance</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Technology Architecture Review</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Pre-Bid Technical Advisory</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> DPDP Act 2023 Alignment</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Digital Adoption Management</li>
          </ul>
          <div class="egov-btn-row">
            <a asp-page="/Contact" class="btn btn-primary btn-glow btn-md"><span class="btn-glow-label">Discuss Your Requirements</span><svg class="btn-glow-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg></a>
            <a asp-page="/CaseStudies" class="btn btn-outline btn-md">View Projects</a>
          </div>
        </div>
        <div class="egov-ref-panel">
          <span class="egov-eyebrow">Reference Projects</span>
          <!-- TODO-WG: each public-sector reference below must have approved public listing before publishing. -->
          <ul class="egov-ref-list">
            <li class="egov-ref-item">
              <span class="egov-ref-logo"><img src="/images/logos/gov/BEE logo.svg" alt="Bureau of Energy Efficiency" loading="lazy" /></span>
              <span>
                <p class="egov-ref-name">Bureau of Energy Efficiency</p>
                <p class="egov-ref-proj">Market Surveillance &amp; Compliance Platform</p>
              </span>
            </li>
            <li class="egov-ref-item">
              <span class="egov-ref-logo"><img src="/images/logos/gov/qci.png" alt="Quality Council of India" loading="lazy" /></span>
              <span>
                <p class="egov-ref-name">Quality Council of India</p>
                <p class="egov-ref-proj">SAMAR Certification Platform</p>
              </span>
            </li>
            <li class="egov-ref-item">
              <span class="egov-ref-logo"><img src="/images/logos/gov/parliament-cafeteria.svg" alt="Parliament of India" loading="lazy" /></span>
              <span>
                <p class="egov-ref-name">Parliament of India</p>
                <p class="egov-ref-proj">Sansad Cafeteria Management System</p>
              </span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="egov-build">
    <div class="container">
      <div class="egov-build-head">
        <span class="egov-eyebrow">Capabilities</span>
        <h2 class="egov-h2">What Our Consulting Practice Delivers</h2>
        <p>Advisory grounded in real government delivery — not frameworks built for boardrooms.</p>
      </div>
      <div class="egov-build-grid">
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg></span>
          <h3>e-Governance Strategy &amp; Roadmap</h3>
          <p>3-year digital transformation roadmaps translating ministry objectives and Digital India mandates into procurable, deployable plans.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/></svg></span>
          <h3>RFP &amp; Tender Specification Writing</h3>
          <p>Technically precise RFP drafting aligned with GFR 2017 — preventing specification bias and ensuring capable vendors respond.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg></span>
          <h3>Independent Vendor Evaluation</h3>
          <p>Objective assessment of technical proposals — scoring methodology, capability benchmarks, and risk identification for selection committees.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
          <h3>PMU Setup &amp; Programme Governance</h3>
          <p>Project Management Unit design, monitoring frameworks, escalation matrices, and digital adoption management for large programmes.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg></span>
          <h3>Technology Architecture Review</h3>
          <p>Independent audit of proposed technology stacks — NIC compatibility, DPDP Act 2023 alignment, and scalability assessment.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5.76.76 1.23 1.52 1.41 2.5"/></svg></span>
          <h3>Pre-Bid Advisory at No Cost</h3>
          <p>Vendor-neutral technical advisory before tenders are floated — helping departments write better RFPs and avoid common procurement failures.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="egov-certs">
    <div class="container">
      <div class="sect-head">
        <span class="egov-eyebrow">Government &amp; Public Sector</span>
        <h2 class="egov-h2">Certifications</h2>
      </div>
      <!-- TODO-WG: confirm the exact list of held certifications; replace any seal below with the real certificate. -->
      <div class="cert-seals-row">
        <div class="cert-seal-card"><div class="cert-seal-img-wrap"><img class="cert-seal-img" src="/images/credentials/cmmi-l5.png" alt="CMMI Level 5 certified" loading="lazy" /></div><div class="cert-seal-card-name">CMMI Level 5</div></div>
        <div class="cert-seal-card"><div class="cert-seal-img-wrap"><img class="cert-seal-img" src="/images/credentials/iso-27001-2022.png" alt="ISO 27001:2022 certified" loading="lazy" /></div><div class="cert-seal-card-name">Information Security</div></div>
        <div class="cert-seal-card"><div class="cert-seal-img-wrap"><img class="cert-seal-img" src="/images/credentials/iso-9001-2015.png" alt="ISO 9001:2015 certified" loading="lazy" /></div><div class="cert-seal-card-name">Quality Management</div></div>
        <div class="cert-seal-card"><div class="cert-seal-img-wrap"><img class="cert-seal-img" src="/images/credentials/iso-20000-2018.png" alt="ISO 20000:2018 certified" loading="lazy" /></div><div class="cert-seal-card-name">IT Service Management</div></div>
        <div class="cert-seal-card"><div class="cert-seal-img-wrap"><img class="cert-seal-img" src="/images/logos/gov/Start up logo.svg" alt="DPIIT — Startup India recognised" loading="lazy" onerror="this.style.display='none'; this.parentNode.classList.add('reg-card-logo--fallback'); this.parentNode.setAttribute('aria-hidden','true'); this.parentNode.textContent='DPIIT';" /></div><div class="cert-seal-card-name">Startup India / DPIIT</div></div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="egov-faq">
    <div class="container">
      <div class="sect-head">

        <h2 class="egov-h2">Frequently Asked Questions</h2>
      </div>
      <!-- TODO-WG: verify each Q&A pairing and all compliance/client claims (ISO version, certifications, named bodies) before publishing. -->
      <div class="faq-wrap">
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Does Webority provide pre-bid technical advisory before a government tender is floated?</button>
          <div class="faq-a"><p>Yes — and at no cost to the department. We provide vendor-neutral pre-bid advisory to help departments define accurate technical scope, identify compliance requirements, and structure RFPs that attract capable vendors. This service is offered as a professional courtesy grounded in our 13+ years of government IT delivery experience. There is no obligation to engage Webority as a vendor.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">How does Webority help government departments write better RFPs?</button>
          <div class="faq-a"><p>Our consulting team reviews existing scope documents, identifies specification gaps or bias, and helps rewrite technical requirements aligned with GFR 2017 procurement rules. We help departments avoid common failure points — vague scope, unrealistic timelines, and non-standardised evaluation criteria. The output is a technically defensible RFP that procurement officers can float with confidence.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">What is PMU support and when does a government department need it?</button>
          <div class="faq-a"><p>Project Management Unit (PMU) support is relevant when departments are implementing large, multi-vendor digital programmes without in-house programme management capacity. We set up governance structures, monitoring frameworks, and escalation matrices — then manage day-to-day coordination between the department and delivery vendors. PMU support is particularly valuable for Smart Cities, NHM digital programmes, and state e-governance initiatives.</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA strip -->
  <section class="egov-cta">
    <div class="container">
      <h2>Planning a digital transformation programme?</h2>
      <p>Bring us the policy mandate or the draft scope — we’ll turn it into a procurable, defensible roadmap.</p>
      <a asp-page="/Contact" class="btn btn-primary btn-glow btn-md"><span class="btn-glow-label">Contact Us</span><svg class="btn-glow-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg></a>
    </div>
  </section>

@section HeadStyles {
    <link rel="stylesheet" href="~/css/pages/service-consulting.css" />
}
