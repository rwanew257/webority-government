@page
@model Webority.Web.GovIndia.Pages.Services.AiAnalyticsModel
@{
    ViewData["Title"] = "Data Analytics & AI Solutions for Government India";
    ViewData["Description"] = "AI-powered decision-support, predictive analytics and intelligent automation for Indian government departments — NDAP-compatible, MeitY AI policy aligned, data localised in India.";
    ViewData["ActiveNav"] = "services";
    ViewData["BodyClass"] = "services-page";
}
<!-- Hero -->
  <section class="egov-hero">
    <div class="container">
      <div class="egov-hero-content">
        <h1>Data Analytics &amp; AI Solutions for Government India</h1>
        <p class="egov-hero-lead">AI-powered decision-support, predictive analytics, and intelligent automation — helping departments move from reactive administration to proactive, data-informed governance.</p>
        <p class="svc-hero-standards">NDAP-Compatible   ·   MeitY AI Policy Aligned   ·   Data Localised in India</p>
      </div>
    </div>
  </section>

  <!-- What We Deliver -->
  <section class="egov-band">
    <div class="container">
      <div class="egov-band-grid">
        <div>
          <span class="egov-eyebrow">What We Deliver</span>
          <h2 class="egov-h2">Smarter Governance Starts with Better Data</h2>
          <p class="copy">We build AI-powered decision-support tools, predictive analytics platforms, and automation systems tailored for departments managing large volumes of citizen data, field reports, or regulatory information.</p>
          <ul class="egov-checklist">
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> AI-powered policy &amp; scheme monitoring</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Predictive analytics for public health</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> NLP-powered citizen query chatbots</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Automated document processing</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Fraud detection for financial schemes</li>
            <li><span class="egov-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> Computer vision for field inspection</li>
          </ul>
          <div class="egov-btn-row">
            <a asp-page="/Contact" class="btn btn-primary btn-glow btn-md"><span class="btn-glow-label">Discuss Your Requirements</span><svg class="btn-glow-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg></a>
            <a asp-page="/CaseStudies" class="btn btn-outline btn-md">View Projects</a>
          </div>
        </div>
        <div class="egov-ref-panel">
          <span class="egov-eyebrow">Reference Projects</span>
          <!-- TODO-WG: each public-sector reference below must have approved public listing before publishing. -->
          <ul class="egov-ref-list">
            <li class="egov-ref-item">
              <span class="egov-ref-logo"><img src="/images/logos/gov/BEE logo.svg" alt="Bureau of Energy Efficiency — Analytics" loading="lazy" /></span>
              <span>
                <p class="egov-ref-name">Bureau of Energy Efficiency — Analytics</p>
                <p class="egov-ref-proj">Data analytics &amp; compliance monitoring for BEE’s Market Surveillance programme — real-time dashboards across all State Designated Agencies</p>
              </span>
            </li>
            <li class="egov-ref-item">
              <span class="egov-ref-logo"><img src="/images/logos/gov/Sickle Scan logo 64px.svg" alt="Ministry of Tribal Affairs — Health Analytics" loading="lazy" /></span>
              <span>
                <p class="egov-ref-name">Ministry of Tribal Affairs — Health Analytics</p>
                <p class="egov-ref-proj">Sickle Scan health-data analytics for disease surveillance &amp; field screening — offline-first, MoH reporting integration</p>
              </span>
            </li>
            <li class="egov-ref-item">
              <span class="egov-ref-logo"><img src="/images/logos/gov/vasudha-foundation.png" alt="Vasudha Foundation — Environmental Analytics" loading="lazy" /></span>
              <span>
                <p class="egov-ref-name">Vasudha Foundation — Environmental Analytics</p>
                <p class="egov-ref-proj">Environment &amp; sustainability data platform with GIS visualisation — air quality, forest cover &amp; programme data on a single geographic layer for statewide monitoring</p>
              </span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="egov-build">
    <div class="container">
      <div class="egov-build-head">
        <span class="egov-eyebrow">Capabilities</span>
        <h2 class="egov-h2">AI Capabilities We Build for Government</h2>
        <p>Production-grade AI features deployed in real government environments — not prototypes.</p>
      </div>
      <div class="egov-build-grid">
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 17 0z"/></svg></span>
          <h3>Multilingual AI Chatbots</h3>
          <p>Voice and text chatbots in 12+ Indian languages — handling citizen queries, grievance routing, and scheme eligibility on WhatsApp, IVRS, and web portals 24×7.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/></svg></span>
          <h3>Document Intelligence &amp; OCR</h3>
          <p>Automated extraction, classification, and routing of government documents — reducing manual processing time by 80%+ with AI-powered pipelines.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></span>
          <h3>DBT Fraud &amp; Anomaly Detection</h3>
          <p>AI-powered monitoring flagging duplicate beneficiaries, irregular disbursements, and ghost entries in welfare scheme databases in real time.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3v18h18"/><rect x="7" y="11" width="3" height="6"/><rect x="13" y="7" width="3" height="10"/></svg></span>
          <h3>Scheme Monitoring Dashboards</h3>
          <p>Real-time NLP-powered dashboards aggregating field reports, SMS data, and beneficiary feedback into ministry-level programme insight.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></span>
          <h3>Predictive Health &amp; Surveillance</h3>
          <p>Disease outbreak prediction, resource demand forecasting, and population health analytics for NHM, Ayushman Bharat, and national health missions.</p>
        </article>
        <article class="egov-build-card">
          <span class="egov-build-ic" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg></span>
          <h3>MLOps &amp; LLMOps in Production</h3>
          <p>End-to-end AI pipeline management — model versioning, drift monitoring, and retraining cycles — deployed on NIC/MeghRaj sovereign infrastructure.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="egov-certs">
    <div class="container">
      <div class="sect-head">
        <span class="egov-eyebrow">Government &amp; Public Sector</span>
        <h2 class="egov-h2">Certifications</h2>
      </div>
      <!-- TODO-WG: confirm the exact list of held certifications; replace any seal below with the real certificate. -->
      <div class="cert-seals-row">
        <div class="cert-seal-card"><div class="cert-seal-img-wrap"><img class="cert-seal-img" src="/images/credentials/cmmi-l5.png" alt="CMMI Level 5 certified" loading="lazy" /></div><div class="cert-seal-card-name">CMMI Level 5</div></div>
        <div class="cert-seal-card"><div class="cert-seal-img-wrap"><img class="cert-seal-img" src="/images/credentials/iso-27001-2022.png" alt="ISO 27001:2022 certified" loading="lazy" /></div><div class="cert-seal-card-name">Information Security</div></div>
        <div class="cert-seal-card"><div class="cert-seal-img-wrap"><img class="cert-seal-img" src="/images/credentials/iso-9001-2015.png" alt="ISO 9001:2015 certified" loading="lazy" /></div><div class="cert-seal-card-name">Quality Management</div></div>
        <div class="cert-seal-card"><div class="cert-seal-img-wrap"><img class="cert-seal-img" src="/images/credentials/iso-20000-2018.png" alt="ISO 20000:2018 certified" loading="lazy" /></div><div class="cert-seal-card-name">IT Service Management</div></div>
        <div class="cert-seal-card"><div class="cert-seal-img-wrap"><img class="cert-seal-img" src="/images/logos/gov/Start up logo.svg" alt="DPIIT — Startup India recognised" loading="lazy" onerror="this.style.display='none'; this.parentNode.classList.add('reg-card-logo--fallback'); this.parentNode.setAttribute('aria-hidden','true'); this.parentNode.textContent='DPIIT';" /></div><div class="cert-seal-card-name">Startup India / DPIIT</div></div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="egov-faq">
    <div class="container">
      <div class="sect-head">

        <h2 class="egov-h2">Frequently Asked Questions</h2>
      </div>
      <!-- TODO-WG: verify each Q&A pairing and all compliance/client claims (ISO version, certifications, named bodies) before publishing. -->
      <div class="faq-wrap">
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Is government citizen data kept within India for all AI deployments?</button>
          <div class="faq-a"><p>Webority Technologies provides AI-powered analytics platforms, RAG pipeline-based policy intelligence tools, NLP chatbots in 12+ Indian languages, document intelligence systems, fraud detection platforms, and scheme monitoring dashboards for India’s public sector. All AI systems are deployed within DPDP Act 2023-compliant, NIC-compatible architectures aligned with MeitY’s responsible AI guidelines. Proven at Bureau of Energy Efficiency’s Market Surveillance programme and Ministry of Tribal Affairs’ Sickle Scan platform.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">Can Webority’s AI platforms connect to existing government databases and HMIS?</button>
          <div class="faq-a"><p>Yes. All AI systems and data analytics platforms built by Webority Technologies for government clients are deployed on NIC National Data Centres or MeghRaj GI Cloud — 100% within India. This satisfies DPDP Act 2023 data localisation requirements and GoI data sovereignty policy. No government data transits through foreign servers at any point in the pipeline.</p></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" aria-expanded="false">How are AI model decisions made auditable for government accountability?</button>
          <div class="faq-a"><p>RAG (Retrieval-Augmented Generation) combines a large language model with a searchable knowledge base — enabling AI to answer using only verified, department-approved data rather than general internet training data. For government, this means dashboards and policy intelligence tools that cite only official data sources, are explainable for audit purposes, and comply with MeitY’s AI ethical framework. Webority deploys RAG pipelines using LangChain and AutoGen within secure, NIC-compatible infrastructure.</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA strip -->
  <section class="egov-cta">
    <div class="container">
      <h2>Planning an AI or analytics initiative?</h2>
      <p>Tell us about your department, the data you hold, and the decisions you need to support — we’ll map the delivery.</p>
      <a asp-page="/Contact" class="btn btn-primary btn-glow btn-md"><span class="btn-glow-label">Contact Us</span><svg class="btn-glow-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg></a>
    </div>
  </section>

@section HeadStyles {
    <link rel="stylesheet" href="~/css/pages/service-ai.css" />
}
