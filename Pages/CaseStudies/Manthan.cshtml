@page
@model Webority.Web.GovIndia.Pages.CaseStudies.ManthanModel
@{
    ViewData["Title"] = "Manthan Employee Engagement Platform — Defence PSU";
    ViewData["Description"] = "Manthan — a bilingual, secure employee engagement platform for a Ministry of Defence PSU, connecting 17 units across a mobile app and a role-based web portal with full audit logging.";
    ViewData["ActiveNav"] = "case-studies";
    ViewData["BodyClass"] = "case-detail-page";
}
<section class="cs-hero cs-hero-manthan">
    <div class="container">
      <div class="cs-hero-content">
        <nav class="cs-breadcrumb" aria-label="Breadcrumb">
          <a asp-page="/CaseStudies">Case Studies</a>
          <span class="cs-breadcrumb-sep">/</span>
          <span class="cs-breadcrumb-current">Munitions India Limited</span>
        </nav>
        <span class="cs-eyebrow-light">Ministry of Defence</span>
        <h1>Manthan Employee<br />Engagement Platform</h1>
        <div class="cs-meta">
          <div class="cs-meta-item"><span class="v">17</span><span class="l">Units Connected</span></div>
          <div class="cs-meta-item"><span class="v">8</span><span class="l">Role-Based Access Levels</span></div>
          <div class="cs-meta-item"><span class="v">Bilingual</span><span class="l">Hindi &amp; English</span></div>
        </div>
      </div>
    </div>
  </section>
  
  <section class="sect" style="background:#ffffff;">
    <div class="container">
      <div class="cs-two-col">
        <div>
          <div class="cs-block">
            <span class="cs-eyebrow">The Mandate</span>
            <h2 class="cs-h2">One Secure Platform for a Distributed Defence Workforce</h2>
            <p class="cs-p">A Government of India Public Sector Undertaking under the Ministry of Defence, engaged in the manufacture of ammunition and ordnance, runs its operations across 17 units. Holding the organisation together depends on how reliably information moves between headquarters and the floor of each unit.</p>
            <p class="cs-p">That movement ran on paper. Announcements travelled by notice board and email, while compliance checklists, grievances, incidents, ideas, and suggestions were collected on forms with no auditable trail and no real-time view for leadership. Webority Technologies engineered Manthan to bring every employee, voice, and workflow onto one secure platform, accessible from any phone in Hindi or English.</p>
          </div>
        </div>
        
        <aside class="cs-info-card cs-info-card--v2 cs-info-card--top">
          <div class="cs-info-row">
            <div class="cs-info-lbl">Client</div>
            <!-- TODO-WG: source doc withholds client name ("Defence PSU"); site elsewhere names Munitions India Limited. Confirm which attribution is approved for publication. -->
            <div class="cs-info-val">Defence PSU</div>
          </div>
          <div class="cs-info-row">
            <div class="cs-info-lbl">Ministry</div>
            <div class="cs-info-val">Ministry of Defence</div>
          </div>
          <div class="cs-info-row">
            <div class="cs-info-lbl">Service Type</div>
            <div class="cs-info-val">Employee Engagement &middot; Mobile App &middot; Web Portal</div>
          </div>
          <div class="cs-info-row">
            <div class="cs-info-lbl">Technology</div>
            <div class="cs-info-val">React Native &middot; Node.js &middot; PostgreSQL &middot; Role-Based Access Control &middot; Bilingual (Hindi/English) &middot; Biometric &amp; OTP Auth &middot; Audit Logging
              <!-- TODO-WG: "ISO 27001 aligned" is a compliance claim — verify before publishing as a badge. -->
            </div>
          </div>
        </aside>
      </div>
    </div>
    
    <div class="cs-block cs-feature-image" style="background-color:#0e1640;">
      <picture>
        <source media="(max-width: 991px)" srcset="/images/case-studies/casestudy-Manthan.png" />
        <img src="/images/logos/gov/Manthan Banner image.png" alt="Manthan employee engagement platform &mdash; mobile app and web portal screens" loading="lazy" />
      </picture>
    </div>
    
    <div class="container">
      <div class="cs-single-col">
        <div>
          <div class="cs-block scope-v2">
            <div class="scope-v2-intro">
              <span class="scope-v2-eyebrow">Scope of Work</span>
              <h2 class="scope-v2-heading">What We Delivered</h2>
              <p class="scope-v2-lead">The platform was built around five integrated capabilities, spanning a mobile app for every employee and a role-based web portal for management. Together they bring communication, compliance, learning, and HR onto a single secure backbone connecting all 17 units.</p>
            </div>
            <ol class="scope-v2-timeline">
              <li class="scope-v2-item">
                <div class="scope-v2-num">01.</div>
                <h3 class="scope-v2-title">Employee Mobile App</h3>
                <p class="scope-v2-desc">Bilingual iOS and Android app with biometric and PIN unlock and OTP login. A daily feed of announcements and recognitions, quick links, and the holiday and training calendar, giving every employee the same single point of access regardless of role.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/Manthan  What we deliver image step1 .png" alt="Manthan employee mobile app screens" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">02.</div>
                <h3 class="scope-v2-title">Engagement &amp; Communication</h3>
                <p class="scope-v2-desc">Targeted announcements from headquarters and units, public and unit-specific discussion forums, direct messaging between colleagues, and workplace surveys including anonymous ones. Built to strengthen transparency and collaboration across every unit.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/Manthan  What we deliver image step2 .png" alt="Engagement and communication screens" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">03.</div>
                <h3 class="scope-v2-title">Submissions &amp; Compliance</h3>
                <p class="scope-v2-desc">One Submissions hub for compliance checklists with photo evidence, ideas, suggestions, incident reports, and grievances. Every item is categorised, routed to the right handler, tracked through its lifecycle, and stored against the employee record.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/Manthan  What we deliver image step3 .png" alt="Submissions and compliance screens" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">04.</div>
                <h3 class="scope-v2-title">Learning, Knowledge &amp; HR Self-Service</h3>
                <p class="scope-v2-desc">An e-learning library with completion tracking, version-controlled policy documents, and a digital e-Patrika magazine, alongside employee self-service for weekly attendance, leave balances, and monthly salary summaries.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/Manthan  What we deliver image step4 .png" alt="Learning, knowledge and HR self-service screens" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">05.</div>
                <h3 class="scope-v2-title">Web Portal with Role-Based Access</h3>
                <p class="scope-v2-desc">A web portal for the seven administrative roles, from Super Admin and Director through Unit Admin, Section Head, Approver, and Verifier to Content Creator. Employees use the mobile app only. Master data, branding, announcements, calendars, and content are managed with unit-scoped permissions and full audit logging on every action.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/Manthan  What we deliver image step5 .png" alt="Role-based web portal screens" loading="lazy" />
                </div>
              </li>
            </ol>
          </div>
          
          <section class="impact-metrics">
            <h2 class="impact-metrics-heading">One Secure System of Record</h2>
            <p class="impact-metrics-lead">Manthan replaced notice boards, email chains, and paper forms with a single platform. Announcements now reach exactly the right audience, every submission carries a complete audit trail, and leadership sees engagement and operations across all 17 units in real time.</p>
            <div class="impact-metrics-grid">
              <article class="impact-metric-card">
                <div class="impact-metric-num">17</div>
                <div class="impact-metric-lbl">Units unified on one platform</div>
              </article>
              <article class="impact-metric-card">
                <div class="impact-metric-num">8</div>
                <div class="impact-metric-lbl">Role-based access levels</div>
              </article>
              <article class="impact-metric-card">
                <div class="impact-metric-num">5</div>
                <div class="impact-metric-lbl">Submission types digitised</div>
              </article>
              <article class="impact-metric-card">
                <div class="impact-metric-num">100<span class="impact-metric-pct">%</span></div>
                <div class="impact-metric-lbl">Audit-logged submissions</div>
              </article>
              <article class="impact-metric-card">
                <div class="impact-metric-num">2</div>
                <div class="impact-metric-lbl">Languages (Hindi &amp; English)</div>
              </article>
              <article class="impact-metric-card">
                <div class="impact-metric-num">Real-time</div>
                <div class="impact-metric-lbl">Leadership visibility</div>
              </article>
            </div>
            <div class="impact-metrics-cta">
              <a class="btn btn-primary btn-glow btn-md" asp-page="/Contact"><span class="btn-glow-label">Discuss a Similar Project</span><svg class="btn-glow-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg></a>
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Other Government Projects — horizontal carousel -->
  <section class="other-projects">
    <div class="container">
      <div class="other-projects-head">
        <h2 class="other-projects-heading">Other Government Projects</h2>
        <div class="other-projects-nav" role="group" aria-label="Carousel navigation">
          <button type="button" class="other-projects-arrow" id="otherProjectsPrev" aria-label="Previous projects">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          </button>
          <button type="button" class="other-projects-arrow" id="otherProjectsNext" aria-label="Next projects">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      </div>
      
      <div class="other-projects-track" id="otherProjectsTrack">
        <article class="op-card op-card--green">
          <a asp-page="/CaseStudies/BeeStarLabel" class="op-card-banner" aria-label="BEE Star Label Compliance">
            <img src="/images/logos/gov/BEE Other project.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">BEE Star Label Compliance</h3>
            <p class="op-card-desc">National platform replacing manual appliance compliance inspections with offline-first field officer app and real-time dashboards for State Designated Agencies.</p>
          </div>
        </article>
        
        <article class="op-card op-card--mint">
          <a asp-page="/CaseStudies" class="op-card-banner" aria-label="Sickle Scan — National Health Screening">
            <img src="/images/logos/gov/Sickle Scan Other project.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">Sickle Scan &mdash; National Health Screening Platform</h3>
            <p class="op-card-desc">Offline-capable, multilingual mobile platform deployed in tribal and remote areas for India&rsquo;s national sickle cell disease eradication initiative.</p>
          </div>
        </article>
        
        <article class="op-card op-card--peach">
          <a asp-page="/CaseStudies/SansadCafeteria" class="op-card-banner" aria-label="Sansad Cafeteria Food Ordering System">
            <img src="/images/logos/gov/Parilament Other project (1).png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">Sansad Cafeteria Food Ordering System</h3>
            <p class="op-card-desc">Multi-outlet facility management system deployed across Parliament premises, serving Members of Parliament in one of India&rsquo;s highest-security environments.</p>
          </div>
        </article>
        
        <article class="op-card op-card--blue">
          <a asp-page="/CaseStudies" class="op-card-banner" aria-label="Manthan — Defence PSU Platform">
            <img src="/images/logos/gov/Manthan Other project.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">Manthan &mdash; Defence PSU Platform</h3>
            <p class="op-card-desc">Enterprise technology platform for Munitions India Limited &mdash; secure, compliant digital infrastructure supporting a Defence Public Sector Undertaking.</p>
          </div>
        </article>
        
        <article class="op-card op-card--red">
          <a asp-page="/CaseStudies" class="op-card-banner" aria-label="NBT India E-commerce">
            <img src="/images/logos/gov/NBT Other project.png.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">National Book Trust E-commerce</h3>
            <p class="op-card-desc">Multilingual e-commerce platform for the Ministry of Education&rsquo;s National Book Trust &mdash; catalogue, payments and fulfilment for India&rsquo;s flagship publisher.</p>
          </div>
        </article>
        
        <article class="op-card op-card--violet">
          <a asp-page="/CaseStudies" class="op-card-banner" aria-label="Parliamentary Affairs Portal">
            <img src="/images/case-studies/parliamentary-affairs.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">Parliamentary Affairs Portal</h3>
            <p class="op-card-desc">Digital workflow platform for the Ministry of Parliamentary Affairs &mdash; legislative session tracking, document management and inter-ministry coordination.</p>
          </div>
        </article>
      </div>
      
      <div class="other-projects-dots" id="otherProjectsDots" role="tablist" aria-label="Carousel pages">
        <button type="button" class="op-dot is-active" aria-label="Page 1"></button>
        <button type="button" class="op-dot" aria-label="Page 2"></button>
        <button type="button" class="op-dot" aria-label="Page 3"></button>
        <button type="button" class="op-dot" aria-label="Page 4"></button>
        <button type="button" class="op-dot" aria-label="Page 5"></button>
        <button type="button" class="op-dot" aria-label="Page 6"></button>
      </div>
    </div>
  </section>

@section HeadStyles {
    <link rel="stylesheet" href="~/css/pages/case-study-shared.css" />
    <link rel="stylesheet" href="~/css/pages/case-manthan.css" />
}

@section BodyScripts {
    <script src="~/js/pages/case-manthan.js"></script>
}
