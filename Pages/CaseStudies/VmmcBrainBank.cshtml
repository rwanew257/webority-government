          </div>
        </article>
        
        <article class="op-card op-card--blue">
          <a asp-page="/CaseStudies/Manthan" class="op-card-banner" aria-label="Manthan — Defence PSU Platform">
            <img src="/images/logos/gov/Manthan Other project.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">Manthan &mdash; Defence PSU Platform</h3>
            <p class="op-card-desc">Enterprise technology platform for Munitions India Limited &mdash; secure, compliant digital infrastructure supporting a Defence Public Sector Undertaking.</p>
          </div>
        </article>
        
        <article class="op-card op-card--red">
          <a asp-page="/CaseStudies" class="op-card-banner" aria-label="NBT India E-commerce">
            <img src="/images/logos/gov/NBT Other project.png.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">National Book Trust E-commerce</h3>
            <p class="op-card-desc">Multilingual e-commerce platform for the Ministry of Education&rsquo;s National Book Trust &mdash; catalogue, payments and fulfilment for India&rsquo;s flagship publisher.</p>
          </div>
        </article>
        
        <article class="op-card op-card--violet">
          <a asp-page="/CaseStudies" class="op-card-banner" aria-label="Parliamentary Affairs Portal">
            <img src="/images/case-studies/parliamentary-affairs.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">Parliamentary Affairs Portal</h3>
            <p class="op-card-desc">Digital workflow platform for the Ministry of Parliamentary Affairs &mdash; legislative session tracking, document management and inter-ministry coordination.</p>
          </div>
        </article>
      </div>
      
      <div class="other-projects-dots" id="otherProjectsDots" role="tablist" aria-label="Carousel pages">
        <button type="button" class="op-dot is-active" aria-label="Page 1"></button>
        <button type="button" class="op-dot" aria-label="Page 2"></button>
        <button type="button" class="op-dot" aria-label="Page 3"></button>
        <button type="button" class="op-dot" aria-label="Page 4"></button>
        <button type="button" class="op-dot" aria-label="Page 5"></button>
        <button type="button" class="op-dot" aria-label="Page 6"></button>
      </div>
    </div>
  </section>

