@page
@model Webority.Web.GovIndia.Pages.CaseStudies.VmmcBrainBankModel
@{
    ViewData["Title"] = "VMMC Brain Bank Exam Management System — Safdarjung Hospital (VMMC)";
    ViewData["Description"] = "A secure, central exam-question bank and paper-assembly platform for the Examination Cell at Vardhman Mahavir Medical College (VMMC), Safdarjung Hospital, under the Ministry of Health & Family Welfare.";
    ViewData["ActiveNav"] = "case-studies";
    ViewData["BodyClass"] = "case-detail-page";
}
<section class="cs-hero cs-hero-safdarjung">
    <div class="container">
      <div class="cs-hero-content">
        <nav class="cs-breadcrumb" aria-label="Breadcrumb">
          <a asp-page="/CaseStudies">Case Studies</a>
          <span class="cs-breadcrumb-sep">/</span>
          <span class="cs-breadcrumb-current">Safdarjung Hospital (VMMC)</span>
        </nav>
        <span class="cs-eyebrow-light">Ministry of Health &amp; Family Welfare</span>
        <h1>VMMC Brain Bank<br />Exam Management System</h1>
        <div class="cs-meta">
          <div class="cs-meta-item"><span class="v">3</span><span class="l">User Roles</span></div>
          <div class="cs-meta-item"><span class="v">3-Use</span><span class="l">Auto-Retirement Rule</span></div>
          <div class="cs-meta-item"><span class="v">OTP</span><span class="l">Secure Role-Based Access</span></div>
        </div>
      </div>
    </div>
  </section>
  
  <section class="sect" style="background:#ffffff;">
    <div class="container">
      <div class="cs-two-col">
        <div>
          <div class="cs-block">
            <span class="cs-eyebrow">The Mandate</span>
            <h2 class="cs-h2">The Integrity of Every Exam a Future Doctor Sits</h2>
            <p class="cs-p">Vardhman Mahavir Medical College, linked to Safdarjung Hospital in Delhi, trains the doctors who will one day staff India&rsquo;s hospitals. Its Examination Cell sits at the centre of that responsibility &mdash; every question paper it produces tests whether a future physician is ready to practise.</p>
            <p class="cs-p">When an exam question is weak, leaked, or overused, two harms compound: a student is assessed on a paper that no longer measures competence, and the institution&rsquo;s standing as a fair, rigorous examiner is quietly eroded. The work runs through three hands &mdash; faculty who write the questions, moderators who assemble them into papers, and the Admin (the Exam Cell in charge) who approves everything and schedules the exams.</p>
            <p class="cs-p">Webority Technologies partnered with VMMC to design and build the digital backbone for the Examination Cell &mdash; a single secure system connecting faculty, moderators, and the Admin, where every question is controlled, every approval is enforced, and every action is recorded.</p>
          </div>
        </div>
        
        <aside class="cs-info-card cs-info-card--v2 cs-info-card--top">
          <div class="cs-info-row">
            <div class="cs-info-lbl">Client</div>
            <div class="cs-info-val">Safdarjung Hospital (VMMC), New Delhi</div>
          </div>
          <div class="cs-info-row">
            <div class="cs-info-lbl">Ministry</div>
            <div class="cs-info-val">Ministry of Health &amp; Family Welfare</div>
          </div>
          <div class="cs-info-row">
            <div class="cs-info-lbl">Service Type</div>
            <div class="cs-info-val">HealthTech &middot; Secure Examination &amp; Assessment</div>
          </div>
          <div class="cs-info-row">
            <div class="cs-info-lbl">Users</div>
            <div class="cs-info-val">Faculty &middot; Moderators &middot; Admin (Examination Cell)</div>
          </div>
        </aside>
      </div>
    </div>
    
    <div class="cs-block cs-feature-image">
      <img src="/images/case-studies/casestudy-VMCC.png" alt="Safdarjung Hospital digital services platform" loading="lazy" />
    </div>
    
    <div class="container">
      <div class="cs-single-col">
        <div>
          <div class="cs-block scope-v2">
            <div class="scope-v2-intro">
              <span class="scope-v2-eyebrow">Scope of Work</span>
              <h2 class="scope-v2-heading">What We Delivered</h2>
              <p class="scope-v2-lead">The platform was built around a controlled question bank and the tools that turn it into finished papers, governed by role-based access and a complete audit trail. Together they connect faculty, moderators, and the Admin on a single secure system.</p>
            </div>
            <ol class="scope-v2-timeline">
              <li class="scope-v2-item">
                <div class="scope-v2-num">01.</div>
                <h3 class="scope-v2-title">Central Question Bank</h3>
                <p class="scope-v2-desc">One controlled repository where every exam question is stored, searchable, and tagged by subject and difficulty &mdash; replacing the scattered Word files, email threads, and personal folders that questions previously lived in.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/VMMC What we deliver image step1 .png" alt="Central question bank screens" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">02.</div>
                <h3 class="scope-v2-title">Overuse Prevention Engine</h3>
                <p class="scope-v2-desc">The system tracks how many times each question has been used and automatically retires it after three uses, so the same questions cannot keep reappearing across papers and leaking to students.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/VMMC What we deliver image step2 .png" alt="Overuse prevention engine screens" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">03.</div>
                <h3 class="scope-v2-title">Two-Stage Approval Workflow</h3>
                <p class="scope-v2-desc">Faculty submit questions and the Admin approves them into the bank. Moderators then assemble papers from approved questions, and the Admin approves the finished paper before it goes live &mdash; nothing reaches an exam hall unchecked.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/VMMC What we deliver image step3 .png" alt="Two-stage approval workflow screens" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">04.</div>
                <h3 class="scope-v2-title">Accountability &amp; Audit Log</h3>
                <p class="scope-v2-desc">A complete history and audit log records who did what and when &mdash; across question entry, moderation, approval, and paper assembly &mdash; giving the Examination Cell a defensible, tamper-evident record of every decision.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/VMMC What we deliver image step4 .png" alt="Accountability and audit log screens" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">05.</div>
                <h3 class="scope-v2-title">Secure, Role-Based Access</h3>
                <p class="scope-v2-desc">Login with OTP and role-based permissions, so faculty, moderators, and the Admin see and do only what their role allows &mdash; shielding sensitive assessment content from anyone outside its proper handling chain.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/VMMC What we deliver image step5 .png" alt="Secure role-based access screens" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">06.</div>
                <h3 class="scope-v2-title">Automated Paper Assembly &amp; Export</h3>
                <p class="scope-v2-desc">Papers are assembled from the bank, balanced for difficulty, and exported as clean PDFs &mdash; both the question paper and the answer key, ready to print &mdash; replacing the slow, error-prone work of building a balanced paper by hand.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/VMMC What we deliver image step6 .png" alt="Automated paper assembly and export screens" loading="lazy" />
                </div>
              </li>
            </ol>
          </div>
          
          <section class="impact-metrics">
            <h2 class="impact-metrics-heading">One Secure System for the Entire Exam Lifecycle</h2>
            <p class="impact-metrics-lead">VMMC Brain Bank replaces a scattered, manual, error-prone way of making exam papers with a single secure system. Questions stay organised, overuse is prevented automatically, proper approvals are enforced, and everything is recorded &mdash; so the Examination Cell saves time and the whole process becomes more accurate, transparent, and trustworthy.</p>
            <div class="impact-metrics-grid">
              <article class="impact-metric-card">
                <div class="impact-metric-num">One</div>
                <div class="impact-metric-lbl">Central bank for every exam question</div>
              </article>
              <article class="impact-metric-card">
                <div class="impact-metric-num">3-Use</div>
                <div class="impact-metric-lbl">Automatic question retirement preventing overuse</div>
              </article>
              <article class="impact-metric-card">
                <div class="impact-metric-num">100<span class="impact-metric-pct">%</span></div>
                <div class="impact-metric-lbl">Audit-logged actions for full accountability</div>
              </article>
            </div>
            <div class="impact-metrics-cta">
              <a class="btn btn-primary btn-glow btn-md" asp-page="/Contact"><span class="btn-glow-label">Discuss a Similar Project</span><svg class="btn-glow-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg></a>
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Other Government Projects — horizontal carousel -->
