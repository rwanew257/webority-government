@page
@model Webority.Web.GovIndia.Pages.CaseStudies.SansadCafeteriaModel
@{
    ViewData["Title"] = "Sansad Cafeteria Management System";
    ViewData["Description"] = "Comprehensive digital platform managing multi-outlet cafeteria operations inside Parliament of India premises — for the ITDC under the Ministry of Parliamentary Affairs.";
    ViewData["ActiveNav"] = "case-studies";
    ViewData["BodyClass"] = "case-detail-page";
}
<section class="cs-hero cs-hero-parliament">
    <div class="container">
      <div class="cs-hero-content">
        <nav class="cs-breadcrumb" aria-label="Breadcrumb">
          <a asp-page="/CaseStudies">Case Studies</a>
          <span class="cs-breadcrumb-sep">/</span>
          <span class="cs-breadcrumb-current">Parliament of India</span>
        </nav>
        <span class="cs-eyebrow-light">Ministry of Parliamentary Affairs</span>
        <h1>Sansad Cafeteria<br />Management System</h1>
        <div class="cs-meta">
          <div class="cs-meta-item"><span class="v">Multi</span><span class="l">Outlet Management</span></div>
          <div class="cs-meta-item"><span class="v">High</span><span class="l">Security Grade</span></div>
          <div class="cs-meta-item"><span class="v">100<span class="cs-meta-pct">%</span></span><span class="l">Digital Operations</span></div>
        </div>
      </div>
    </div>
  </section>
  
  <section class="sect" style="background:#ffffff;">
    <div class="container">
      <div class="cs-two-col">
        <div>
          <div class="cs-block">
            <span class="cs-eyebrow">Project Overview</span>
            <h2 class="cs-h2">Digitising Operations Inside India&rsquo;s Parliament</h2>
            <p class="cs-p">The Sansad Cafeteria Management System is a comprehensive digital platform deployed across multiple cafeteria outlets within Parliament premises. The platform manages every aspect of food service operations &mdash; from daily demand forecasting linked to Parliamentary sessions to multi-outlet billing, inventory management, and financial reconciliation.</p>
            <p class="cs-p">Given the deployment environment &mdash; one of India&rsquo;s most high-security premises &mdash; the platform required stringent access controls, audit logging, and compliance with Parliamentary security protocols throughout the development and deployment process.</p>
          </div>
        </div>
        
        <aside class="cs-info-card cs-info-card--v2 cs-info-card--top">
          <div class="cs-info-row">
            <div class="cs-info-lbl">Client</div>
            <div class="cs-info-val">Parliament of India &middot; ITDC</div>
          </div>
          <div class="cs-info-row">
            <div class="cs-info-lbl">Ministry</div>
            <div class="cs-info-val">Ministry of Parliamentary Affairs</div>
          </div>
          <div class="cs-info-row">
            <div class="cs-info-lbl">Platform</div>
            <div class="cs-info-val">Custom Software &middot; Facility Management</div>
          </div>
          <div class="cs-info-row">
            <div class="cs-info-lbl">Technology</div>
            <div class="cs-info-tech">
              <span class="cs-tech-chip" aria-label="React.js">
                <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="16" cy="16" r="2.4" fill="#61DAFB"/><g fill="none" stroke="#61DAFB" stroke-width="1.6"><ellipse cx="16" cy="16" rx="11" ry="4.2"/><ellipse cx="16" cy="16" rx="11" ry="4.2" transform="rotate(60 16 16)"/><ellipse cx="16" cy="16" rx="11" ry="4.2" transform="rotate(120 16 16)"/></g></svg>
              </span>
              <span class="cs-tech-chip" aria-label="Node.js">
                <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill="#539E43" d="M16 3 4 9.5v13L16 29l12-6.5v-13L16 3zm0 2.4 9.6 5.2v10.8L16 26.6 6.4 21.4V10.6L16 5.4z"/><path fill="#539E43" d="M20.5 16.7c0-1.8-1-2.4-3.2-2.7-2.2-.3-2.4-.5-2.4-1.1 0-.5.2-1.1 1.8-1.1 1.4 0 1.9.3 2.1 1.2 0 .1.1.2.2.2h1.1c.1 0 .1 0 .2-.1l.1-.2c-.2-1.8-1.4-2.7-3.7-2.7-2.1 0-3.3.9-3.3 2.4 0 1.6 1.3 2.1 3.3 2.3 2.4.2 2.6.6 2.6 1.1 0 .9-.7 1.3-2.4 1.3-2.1 0-2.6-.5-2.7-1.6 0-.1-.1-.2-.2-.2h-1.1c-.1 0-.2.1-.2.2 0 1.4 1 3 4.2 3 2.4 0 3.7-.9 3.7-2.7z"/></svg>
              </span>
              <span class="cs-tech-chip" aria-label="PostgreSQL">
                <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill="#336791" d="M25.5 6.5c-1.7-1.7-4.7-1.6-7 .1-1.1-.3-2.4-.4-3.6-.2-2.2.3-4.1 1.6-5.3 3.3-1.2 1.7-2.1 4-2.4 7-.3 3 .3 5.9 1.6 7.7.7.9 1.8 1.4 2.9 1.3.9-.1 1.6-.7 2.2-1.7.5-.8 1-1.7 1.5-2.5.2-.4.4-.7.5-1 0 .8.1 1.5.2 2.2.1.7.4 1.3.7 1.8.4.6 1 1 1.7 1.1.7.1 1.4-.1 2-.5.5-.4.9-1 1.1-1.8.2-.7.3-1.5.3-2.4.2.4.4.7.7 1 .3.3.6.5 1 .6.4.1.8.1 1.2-.1.4-.2.7-.5.9-.9.6-1 .5-2.5-.1-4.1-.5-1.4-1.5-2.7-2.7-3.6 1.5-1.5 2.2-3.5 1.5-5.3z"/><path fill="#fff" d="M18 18c-.4 0-.8.4-.8.9 0 .5.4.9.9.9.5 0 .8-.4.8-.9 0-.5-.4-.9-.9-.9zm-5.5-1.5c-.3 0-.6.3-.6.7 0 .4.3.7.7.7.4 0 .6-.3.6-.7 0-.4-.3-.7-.7-.7zm6.5 4c-.4.7-.9 1.4-1.4 2.1-.2.3-.4.5-.5.5-.1 0-.2-.1-.3-.2-.1-.2-.1-.4-.1-.6 0-.2 0-.4.1-.6.2-.6.3-1.3.4-1.9l1.8.7zm-4 2.2c.2-.1.4-.3.5-.5.3-.5.5-1.1.6-1.8.1-.7.1-1.5 0-2.2-.1-.5-.3-.9-.6-1.3-.5-.6-1.2-.8-1.9-.7-.6.1-1.1.5-1.4 1.1-.4.7-.5 1.6-.4 2.5.1.9.4 1.8.9 2.4.4.5.9.8 1.5.8.3 0 .6-.1.8-.3z"/></svg>
              </span>
              <span class="cs-tech-chip" aria-label="REST APIs">
                <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="16" cy="16" r="11" fill="none" stroke="#6a3df0" stroke-width="1.8"/><path fill="none" stroke="#6a3df0" stroke-width="1.6" stroke-linecap="round" d="M5 16h22M16 5c3 3.5 4.5 7 4.5 11s-1.5 7.5-4.5 11M16 5c-3 3.5-4.5 7-4.5 11s1.5 7.5 4.5 11"/></svg>
              </span>
            </div>
          </div>
        </aside>
      </div>
    </div>
    
    <div class="cs-block cs-feature-image">
      <picture>
        <source media="(max-width: 991px)" srcset="/images/case-studies/casestudy-sansad.png" />
        <img src="/images/logos/gov/Sansad Banner.png" alt="Sansad Cafeteria Management System" loading="lazy" />
      </picture>
    </div>
    
    <div class="container">
      <div class="cs-single-col">
        <div>
          <div class="cs-block scope-v2">
            <div class="scope-v2-intro">
              <span class="scope-v2-eyebrow">Scope of Work</span>
              <h2 class="scope-v2-heading">What We Delivered</h2>
              <p class="scope-v2-lead">The platform was built around six integrated modules &mdash; from a unified multi-outlet operations dashboard to session-linked demand planning, role-based access, billing, inventory and financial reconciliation &mdash; all engineered to operate inside one of India&rsquo;s highest-security environments.</p>
            </div>
            <ol class="scope-v2-timeline">
              <li class="scope-v2-item">
                <div class="scope-v2-num">01.</div>
                <h3 class="scope-v2-title">Multi-Outlet Operations Platform</h3>
                <p class="scope-v2-desc">Unified digital management system for all cafeteria outlets within Parliament premises &mdash; centralised dashboard with outlet-level control and reporting.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/Sansard What we deliver image step1 .png" alt="Multi-outlet operations platform screens" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">02.</div>
                <h3 class="scope-v2-title">Session-Linked Demand Management</h3>
                <p class="scope-v2-desc">Automated demand forecasting and menu planning linked to Parliamentary session schedules &mdash; ensuring accurate provisioning based on attendance and sitting days.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/Sansard What we deliver image step2.png" alt="Session-linked demand management screens" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">03.</div>
                <h3 class="scope-v2-title">Role-Based Access Control</h3>
                <p class="scope-v2-desc">Multi-tiered access system for cafeteria managers, outlet staff, billing personnel, and administrative oversight &mdash; with complete audit trails on every action.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/Sansard What we deliver image step3.png" alt="Role-based access control screens" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">04.</div>
                <h3 class="scope-v2-title">Billing &amp; POS Integration</h3>
                <p class="scope-v2-desc">Digital billing across all outlets with POS terminal integration, token management, and real-time transaction tracking.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/Sansard What we deliver image step4.png" alt="Billing and POS integration screens" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">05.</div>
                <h3 class="scope-v2-title">Inventory &amp; Procurement Management</h3>
                <p class="scope-v2-desc">End-to-end inventory tracking, stock alerts, supplier management, and purchase order workflows aligned with government procurement rules.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/Sansard What we deliver image step5.png" alt="Inventory and procurement management screens" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">06.</div>
                <h3 class="scope-v2-title">Financial Reporting &amp; Reconciliation</h3>
                <p class="scope-v2-desc">Automated daily, weekly, and monthly financial reports with outlet-wise P&amp;L, collection reconciliation, and audit-ready documentation.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/Sansard What we deliver image step6.png" alt="Financial reporting and reconciliation screens" loading="lazy" />
                </div>
              </li>
            </ol>
          </div>
          
          <section class="impact-metrics">
            <h2 class="impact-metrics-heading">Impact Metrics</h2>
            <p class="impact-metrics-lead">Real results from a deployment inside one of India&rsquo;s highest-security environments.</p>
            <div class="impact-metrics-grid">
              <article class="impact-metric-card">
                <div class="impact-metric-num">100<span class="impact-metric-pct">%</span></div>
                <div class="impact-metric-lbl">Manual operations digitised</div>
              </article>
              <article class="impact-metric-card">
                <div class="impact-metric-num">Multi</div>
                <div class="impact-metric-lbl">Outlet unified on one platform</div>
              </article>
              <article class="impact-metric-card">
                <div class="impact-metric-num">Zero</div>
                <div class="impact-metric-lbl">Audit non-compliance since go-live</div>
              </article>
            </div>
            <div class="impact-metrics-cta">
              <a class="btn btn-primary btn-glow btn-md" asp-page="/Contact"><span class="btn-glow-label">Discuss a Similar Project</span><svg class="btn-glow-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg></a>
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Other Government Projects — horizontal carousel -->
  <section class="other-projects">
    <div class="container">
      <div class="other-projects-head">
        <h2 class="other-projects-heading">Other Government Projects</h2>
        <div class="other-projects-nav" role="group" aria-label="Carousel navigation">
          <button type="button" class="other-projects-arrow" id="otherProjectsPrev" aria-label="Previous projects">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          </button>
          <button type="button" class="other-projects-arrow" id="otherProjectsNext" aria-label="Next projects">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      </div>
      
      <div class="other-projects-track" id="otherProjectsTrack">
        <article class="op-card op-card--green">
          <a asp-page="/CaseStudies/BeeStarLabel" class="op-card-banner" aria-label="BEE Star Label Compliance">
            <img src="/images/logos/gov/BEE Other project.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">BEE Star Label Compliance</h3>
            <p class="op-card-desc">National platform replacing manual appliance compliance inspections with offline-first field officer app and real-time dashboards for State Designated Agencies.</p>
          </div>
        </article>
        
        <article class="op-card op-card--mint">
          <a asp-page="/CaseStudies" class="op-card-banner" aria-label="Sickle Scan — National Health Screening">
            <img src="/images/logos/gov/Sickle Scan Other project.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">Sickle Scan &mdash; National Health Screening Platform</h3>
            <p class="op-card-desc">Offline-capable, multilingual mobile platform deployed in tribal and remote areas for India&rsquo;s national sickle cell disease eradication initiative.</p>
          </div>
        </article>
        
        <article class="op-card op-card--peach">
          <a asp-page="/CaseStudies/SansadCafeteria" class="op-card-banner" aria-label="Sansad Cafeteria Food Ordering System">
            <img src="/images/logos/gov/Parilament Other project (1).png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">Sansad Cafeteria Food Ordering System</h3>
            <p class="op-card-desc">Multi-outlet facility management system deployed across Parliament premises, serving Members of Parliament in one of India&rsquo;s highest-security environments.</p>
          </div>
        </article>
        
        <article class="op-card op-card--blue">
          <a asp-page="/CaseStudies/Manthan" class="op-card-banner" aria-label="Manthan — Defence PSU Platform">
            <img src="/images/logos/gov/Manthan Other project.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">Manthan &mdash; Defence PSU Platform</h3>
            <p class="op-card-desc">Enterprise technology platform for Munitions India Limited &mdash; secure, compliant digital infrastructure supporting a Defence Public Sector Undertaking.</p>
          </div>
        </article>
        
        <article class="op-card op-card--red">
          <a asp-page="/CaseStudies" class="op-card-banner" aria-label="NBT India E-commerce">
            <img src="/images/logos/gov/NBT Other project.png.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">National Book Trust E-commerce</h3>
            <p class="op-card-desc">Multilingual e-commerce platform for the Ministry of Education&rsquo;s National Book Trust &mdash; catalogue, payments and fulfilment for India&rsquo;s flagship publisher.</p>
          </div>
        </article>
        
        <article class="op-card op-card--violet">
          <a asp-page="/CaseStudies" class="op-card-banner" aria-label="Parliamentary Affairs Portal">
            <img src="/images/case-studies/parliamentary-affairs.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">Parliamentary Affairs Portal</h3>
            <p class="op-card-desc">Digital workflow platform for the Ministry of Parliamentary Affairs &mdash; legislative session tracking, document management and inter-ministry coordination.</p>
          </div>
        </article>
      </div>
      
      <div class="other-projects-dots" id="otherProjectsDots" role="tablist" aria-label="Carousel pages">
        <button type="button" class="op-dot is-active" aria-label="Page 1"></button>
        <button type="button" class="op-dot" aria-label="Page 2"></button>
        <button type="button" class="op-dot" aria-label="Page 3"></button>
        <button type="button" class="op-dot" aria-label="Page 4"></button>
        <button type="button" class="op-dot" aria-label="Page 5"></button>
        <button type="button" class="op-dot" aria-label="Page 6"></button>
      </div>
    </div>
  </section>

@section HeadStyles {
    <link rel="stylesheet" href="~/css/pages/case-study-shared.css" />
    <link rel="stylesheet" href="~/css/pages/case-parliament.css" />
}

@section BodyScripts {
    <script src="~/js/pages/case-parliament.js"></script>
}
