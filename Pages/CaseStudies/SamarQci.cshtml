              </span>
              <span class="cs-tech-chip" aria-label="Microsoft Azure">
                <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><defs><linearGradient id="azGrad1" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#114A8B"/><stop offset="1" stop-color="#0669BC"/></linearGradient><linearGradient id="azGrad2" x1="0" y1="1" x2="1" y2="0"><stop offset="0" stop-color="#3CCBF4"/><stop offset="1" stop-color="#2892DF"/></linearGradient></defs><path fill="url(#azGrad1)" d="M12 4h7l-7 21H6.5c-1.3 0-2.4-1.2-2-2.4L12 4z"/><path fill="#0078D4" d="M13 17h10l-3 8H8l5-8z"/><path fill="url(#azGrad2)" d="M16 4h5l9 21h-5l-2.5-6h-8L16 4z"/></svg>
