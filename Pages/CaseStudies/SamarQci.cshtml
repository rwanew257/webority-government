@page
@model Webority.Web.GovIndia.Pages.CaseStudies.SamarQciModel
@{
    ViewData["Title"] = "SAMAR — Certification & Assessment Platform";
    ViewData["Description"] = "End-to-end certification lifecycle platform for the Quality Council of India — from application and document submission through evaluator workflow to digitally signed certificate issuance.";
    ViewData["ActiveNav"] = "case-studies";
    ViewData["BodyClass"] = "case-detail-page";
}
<section class="cs-hero cs-hero-qci">
    <div class="container">
      <div class="cs-hero-content">
        <nav class="cs-breadcrumb" aria-label="Breadcrumb">
          <a asp-page="/CaseStudies">Case Studies</a>
          <span class="cs-breadcrumb-sep">/</span>
          <span class="cs-breadcrumb-current">Quality Council of India</span>
        </nav>
        <span class="cs-eyebrow-light">DPIIT</span>
        <h1>SAMAR &mdash; Certification &amp;<br />Assessment Platform</h1>
        <div class="cs-meta">
          <div class="cs-meta-item"><span class="v">E2E</span><span class="l">Certification Workflow</span></div>
          <div class="cs-meta-item"><span class="v">Multi</span><span class="l">Level Approvals</span></div>
          <div class="cs-meta-item"><span class="v">Digital</span><span class="l">Certificate Issuance</span></div>
        </div>
      </div>
    </div>
  </section>
  
  <section class="sect" style="background:#ffffff;">
    <div class="container">
      <div class="cs-two-col">
        <div>
          <div class="cs-block">
            <span class="cs-eyebrow">Project Overview</span>
            <h2 class="cs-h2">End-to-End Certification Lifecycle for India&rsquo;s Quality Regulator</h2>
            <p class="cs-p">The Quality Council of India manages certification and accreditation for a wide range of organisations across India. The SAMAR (System for Assessment, Monitoring, and Review) platform digitises the complete certification lifecycle &mdash; from initial application and document submission through evaluator assignment, multi-level review, final approval, and digital certificate issuance.</p>
            <p class="cs-p">By replacing legacy paper-based workflows with a unified digital backbone, SAMAR brings transparency, auditability, and faster turnaround to every stage of the certification process &mdash; benefiting applicant organisations, evaluators, and QCI&rsquo;s administrative teams alike.</p>
          </div>
        </div>
        
        <aside class="cs-info-card cs-info-card--v2 cs-info-card--top">
          <div class="cs-info-row">
            <div class="cs-info-lbl">Client</div>
            <div class="cs-info-val">Quality Council of India (QCI)</div>
          </div>
          <div class="cs-info-row">
            <div class="cs-info-lbl">Ministry</div>
            <div class="cs-info-val">DPIIT &middot; Ministry of Commerce</div>
          </div>
          <div class="cs-info-row">
            <div class="cs-info-lbl">Platform</div>
            <div class="cs-info-val">e-Governance &middot; Workflow Platform &middot; Regulatory</div>
          </div>
          <div class="cs-info-row">
            <div class="cs-info-lbl">Technology</div>
            <div class="cs-info-tech">
              <span class="cs-tech-chip" aria-label="AWS">
