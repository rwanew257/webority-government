@page
@model Webority.Web.GovIndia.Pages.CaseStudies.SsbCybersecurityModel
@{
    ViewData["Title"] = "Cybersecurity Assessment & VAPT — Sashastra Seema Bal";
    ViewData["Description"] = "Comprehensive cybersecurity assessment and VAPT engagement for Sashastra Seema Bal, Ministry of Home Affairs — aligned with CERT-In, NIC and ISO 27001 standards.";
    ViewData["ActiveNav"] = "case-studies";
    ViewData["BodyClass"] = "case-detail-page";
}
<section class="cs-hero cs-hero-ssb">
    <div class="container">
      <div class="cs-hero-content">
        <nav class="cs-breadcrumb" aria-label="Breadcrumb">
          <a asp-page="/CaseStudies">Case Studies</a>
          <span class="cs-breadcrumb-sep">/</span>
          <span class="cs-breadcrumb-current">Sashastra Seema Bal</span>
        </nav>
        <span class="cs-eyebrow-light">Ministry of Home Affairs</span>
        <h1>Cybersecurity Assessment<br />&amp; VAPT</h1>
        <div class="cs-meta">
          <div class="cs-meta-item"><span class="v">CERT</span><span class="l">-In Aligned</span></div>
          <div class="cs-meta-item"><span class="v">MHA</span><span class="l">Security Protocols</span></div>
          <div class="cs-meta-item"><span class="v">Full</span><span class="l">Remediation Roadmap</span></div>
        </div>
      </div>
    </div>
  </section>
  
  <section class="sect" style="background:#ffffff;">
    <div class="container">
      <div class="cs-two-col">
        <div>
          <div class="cs-block">
            <span class="cs-eyebrow">Project Overview</span>
            <h2 class="cs-h2">Security Assessment for a Paramilitary Force</h2>
            <p class="cs-p">Sashastra Seema Bal is a Central Armed Police Force under the Ministry of Home Affairs, responsible for guarding India&rsquo;s borders with Nepal and Bhutan. With an expanding digital infrastructure supporting operations, HR, and administrative functions, SSB required a comprehensive security assessment aligned with GoI cybersecurity mandates.</p>
            <p class="cs-p">This engagement was conducted under strict confidentiality protocols &mdash; all findings, vulnerabilities, and remediation recommendations are classified. The scope covered web applications, network infrastructure, and internal systems.</p>
          </div>
        </div>
        
        <aside class="cs-info-card cs-info-card--v2 cs-info-card--top">
          <div class="cs-info-row">
            <div class="cs-info-lbl">Client</div>
            <div class="cs-info-val">Sashastra Seema Bal (SSB)</div>
          </div>
          <div class="cs-info-row">
            <div class="cs-info-lbl">Ministry</div>
            <div class="cs-info-val">Ministry of Home Affairs</div>
          </div>
          <div class="cs-info-row">
            <div class="cs-info-lbl">Service Type</div>
            <div class="cs-info-val">Cybersecurity &middot; VAPT &middot; Security Audit</div>
          </div>
          <div class="cs-info-row">
            <div class="cs-info-lbl">Standards</div>
            <div class="cs-info-tech">
              <span class="cs-tech-chip" aria-label="CERT-In">
                <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill="#1a2a5e" d="M16 2 4 7v8c0 7.4 5.1 13.6 12 15 6.9-1.4 12-7.6 12-15V7L16 2z"/><path fill="#ffffff" d="m13.6 19.4-3.6-3.6 1.8-1.8 1.8 1.8 5.4-5.4 1.8 1.8-7.2 7.2z"/></svg>
              </span>
              <span class="cs-tech-chip" aria-label="OWASP">
                <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="16" cy="16" r="13" fill="#000000"/><path fill="#ffffff" d="M16 6c-5.5 0-10 4.5-10 10s4.5 10 10 10 10-4.5 10-10S21.5 6 16 6zm0 17c-3.9 0-7-3.1-7-7s3.1-7 7-7 7 3.1 7 7-3.1 7-7 7z"/><circle cx="16" cy="16" r="3" fill="#ffffff"/></svg>
              </span>
              <span class="cs-tech-chip" aria-label="NIC">
                <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="4" y="4" width="24" height="24" rx="3" fill="#ff6b00"/><text x="16" y="21" text-anchor="middle" font-family="Arial, sans-serif" font-size="11" font-weight="700" fill="#ffffff">NIC</text></svg>
              </span>
              <span class="cs-tech-chip" aria-label="ISO 27001">
                <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="16" cy="16" r="13" fill="#0066b3"/><text x="16" y="14" text-anchor="middle" font-family="Arial, sans-serif" font-size="7" font-weight="700" fill="#ffffff">ISO</text><text x="16" y="22" text-anchor="middle" font-family="Arial, sans-serif" font-size="6" font-weight="700" fill="#ffffff">27001</text></svg>
              </span>
            </div>
          </div>
        </aside>
      </div>
    </div>
    
    <div class="cs-block cs-feature-image">
      <img src="/images/case-studies/casestudy-SSB.png" alt="SSB Cybersecurity Assessment &amp; VAPT engagement" loading="lazy" />
    </div>
    
    <div class="container">
      <div class="cs-single-col">
        <div>
          <div class="cs-block scope-v2">
            <div class="scope-v2-intro">
              <span class="scope-v2-eyebrow">Scope of Work</span>
              <h2 class="scope-v2-heading">What We Delivered</h2>
              <p class="scope-v2-lead">The engagement was structured around six integrated workstreams &mdash; from black-box and grey-box application testing through network assessment to CERT-In gap analysis, formal reporting and post-remediation re-testing &mdash; all conducted under strict confidentiality protocols aligned with MHA security directives.</p>
            </div>
            <ol class="scope-v2-timeline">
              <li class="scope-v2-item">
                <div class="scope-v2-num">01.</div>
                <h3 class="scope-v2-title">Web Application Security Assessment</h3>
                <p class="scope-v2-desc">Comprehensive black-box and grey-box testing of SSB&rsquo;s web-facing applications &mdash; covering OWASP Top 10 vulnerabilities, authentication mechanisms, session management, and data exposure risks.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/SSB What we deliver image step1 .png" alt="Web application security assessment" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">02.</div>
                <h3 class="scope-v2-title">Network Infrastructure Assessment</h3>
                <p class="scope-v2-desc">Internal and perimeter network security review &mdash; firewall configurations, network segmentation, open ports, and protocol vulnerability analysis.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/SSB What we deliver image step2 .png" alt="Network infrastructure assessment" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">03.</div>
                <h3 class="scope-v2-title">Vulnerability Classification &amp; Prioritisation</h3>
                <p class="scope-v2-desc">All identified vulnerabilities classified by severity (Critical / High / Medium / Low) with CVSS scoring, business impact assessment, and exploitability ratings.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/SSB What we deliver image step3 .png" alt="Vulnerability classification and prioritisation" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">04.</div>
                <h3 class="scope-v2-title">CERT-In Compliance Review</h3>
                <p class="scope-v2-desc">Gap analysis against CERT-In cybersecurity guidelines and MHA security directives &mdash; identifying non-compliance areas and required remediation steps.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/SSB What we deliver image step4 .png" alt="CERT-In compliance review" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">05.</div>
                <h3 class="scope-v2-title">Formal VAPT Report</h3>
                <p class="scope-v2-desc">Comprehensive security assessment report with executive summary for leadership, detailed technical findings for IT teams, and a prioritised remediation roadmap with timelines.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/SSB What we deliver image step5 .png" alt="Formal VAPT report deliverable" loading="lazy" />
                </div>
              </li>
              <li class="scope-v2-item">
                <div class="scope-v2-num">06.</div>
                <h3 class="scope-v2-title">Remediation Guidance &amp; Re-testing</h3>
                <p class="scope-v2-desc">Post-remediation guidance for SSB&rsquo;s IT team and re-testing of critical vulnerabilities to confirm successful closure.</p>
                <div class="scope-v2-media">
                  <img src="/images/logos/gov/SSB What we deliver image step6 .png" alt="Remediation guidance and re-testing" loading="lazy" />
                </div>
              </li>
            </ol>
          </div>
          
          <section class="impact-metrics">
            <h2 class="impact-metrics-heading">Impact Metrics</h2>
            <p class="impact-metrics-lead">Real results from a confidential engagement conducted under MHA security protocols and aligned with CERT-In, NIC and ISO 27001 standards.</p>
            <div class="impact-metrics-grid">
              <article class="impact-metric-card">
                <div class="impact-metric-num">100<span class="impact-metric-pct">%</span></div>
                <div class="impact-metric-lbl">CERT-In aligned delivery</div>
              </article>
              <article class="impact-metric-card">
                <div class="impact-metric-num">Full</div>
                <div class="impact-metric-lbl">Vulnerability remediation roadmap</div>
              </article>
              <article class="impact-metric-card">
                <div class="impact-metric-num">MHA</div>
                <div class="impact-metric-lbl">Security protocols followed</div>
              </article>
            </div>
            <div class="impact-metrics-cta">
              <a class="btn btn-primary btn-glow btn-md" asp-page="/Contact"><span class="btn-glow-label">Request a Security Assessment</span><svg class="btn-glow-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg></a>
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Other Government Projects — horizontal carousel -->
  <section class="other-projects">
    <div class="container">
      <div class="other-projects-head">
        <h2 class="other-projects-heading">Other Government Projects</h2>
        <div class="other-projects-nav" role="group" aria-label="Carousel navigation">
          <button type="button" class="other-projects-arrow" id="otherProjectsPrev" aria-label="Previous projects">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          </button>
          <button type="button" class="other-projects-arrow" id="otherProjectsNext" aria-label="Next projects">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      </div>
      
      <div class="other-projects-track" id="otherProjectsTrack">
        <article class="op-card op-card--green">
          <a asp-page="/CaseStudies/BeeStarLabel" class="op-card-banner" aria-label="BEE Star Label Compliance">
            <img src="/images/logos/gov/BEE Other project.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">BEE Star Label Compliance</h3>
            <p class="op-card-desc">National platform replacing manual appliance compliance inspections with offline-first field officer app and real-time dashboards for State Designated Agencies.</p>
          </div>
        </article>
        
        <article class="op-card op-card--mint">
          <a asp-page="/CaseStudies" class="op-card-banner" aria-label="Sickle Scan — National Health Screening">
            <img src="/images/logos/gov/Sickle Scan Other project.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">Sickle Scan &mdash; National Health Screening Platform</h3>
            <p class="op-card-desc">Offline-capable, multilingual mobile platform deployed in tribal and remote areas for India&rsquo;s national sickle cell disease eradication initiative.</p>
          </div>
        </article>
        
        <article class="op-card op-card--peach">
          <a asp-page="/CaseStudies/SansadCafeteria" class="op-card-banner" aria-label="Sansad Cafeteria Food Ordering System">
            <img src="/images/logos/gov/Parilament Other project (1).png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">Sansad Cafeteria Food Ordering System</h3>
            <p class="op-card-desc">Multi-outlet facility management system deployed across Parliament premises, serving Members of Parliament in one of India&rsquo;s highest-security environments.</p>
          </div>
        </article>
        
        <article class="op-card op-card--blue">
          <a asp-page="/CaseStudies/Manthan" class="op-card-banner" aria-label="Manthan — Defence PSU Platform">
            <img src="/images/logos/gov/Manthan Other project.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">Manthan &mdash; Defence PSU Platform</h3>
            <p class="op-card-desc">Enterprise technology platform for Munitions India Limited &mdash; secure, compliant digital infrastructure supporting a Defence Public Sector Undertaking.</p>
          </div>
        </article>
        
        <article class="op-card op-card--red">
          <a asp-page="/CaseStudies" class="op-card-banner" aria-label="NBT India E-commerce">
            <img src="/images/logos/gov/NBT Other project.png.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">National Book Trust E-commerce</h3>
            <p class="op-card-desc">Multilingual e-commerce platform for the Ministry of Education&rsquo;s National Book Trust &mdash; catalogue, payments and fulfilment for India&rsquo;s flagship publisher.</p>
          </div>
        </article>
        
        <article class="op-card op-card--violet">
          <a asp-page="/CaseStudies" class="op-card-banner" aria-label="Parliamentary Affairs Portal">
            <img src="/images/case-studies/parliamentary-affairs.png" alt="" loading="lazy" />
          </a>
          <div class="op-card-body">
            <h3 class="op-card-title">Parliamentary Affairs Portal</h3>
            <p class="op-card-desc">Digital workflow platform for the Ministry of Parliamentary Affairs &mdash; legislative session tracking, document management and inter-ministry coordination.</p>
          </div>
        </article>
      </div>
      
      <div class="other-projects-dots" id="otherProjectsDots" role="tablist" aria-label="Carousel pages">
        <button type="button" class="op-dot is-active" aria-label="Page 1"></button>
        <button type="button" class="op-dot" aria-label="Page 2"></button>
        <button type="button" class="op-dot" aria-label="Page 3"></button>
        <button type="button" class="op-dot" aria-label="Page 4"></button>
        <button type="button" class="op-dot" aria-label="Page 5"></button>
        <button type="button" class="op-dot" aria-label="Page 6"></button>
      </div>
    </div>
  </section>

@section HeadStyles {
    <link rel="stylesheet" href="~/css/pages/case-study-shared.css" />
    <link rel="stylesheet" href="~/css/pages/case-ssb.css" />
}

@section BodyScripts {
    <script src="~/js/pages/case-ssb.js"></script>
}
