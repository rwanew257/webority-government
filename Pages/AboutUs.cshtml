@page
@model Webority.Web.GovIndia.Pages.AboutUsModel
@{
    ViewData["Title"] = "About";
    ViewData["Description"] = "Webority Government is the public-sector practice of Webority Technologies — engineered for the scale, scrutiny and standards of Indian Government work.";
    ViewData["ActiveNav"] = "about";
    ViewData["BodyClass"] = "about-page";
}
<section class="svc-hero">
    <div class="container">
      <div class="svc-hero-content">
        <h1>A Decade Delivering for India&rsquo;s Public Sector</h1>
        <p>Webority Technologies is a CMMI Level 5 certified software engineering and AI company headquartered in Gurugram, Haryana. Since 2012, we have partnered with Central Government ministries, paramilitary forces, national regulatory bodies and state institutions.</p>
      </div>
    </div>
  </section>

  <!-- Our Story + stats -->
  <section class="sect sect-story-light">
    <div class="container">
      <div class="story-split">
        <div class="story-img-wrap">
          <img class="story-img-photo" src="/images/logos/gov/About us section.png" alt="Webority Government &mdash; a decade delivering for India&rsquo;s public sector across parliament, ministries, security, compliance, RFP/GeM and delivery" loading="lazy" />
        </div>
        <div class="story-copy">
          <span class="eyebrow">Our Story</span>
          <h2>Not a Company that occasionally takes a Government Project</h2>
          <p>The public sector is a core vertical for us &mdash; with a dedicated delivery team, compliance infrastructure, and institutional knowledge built across 10+ years of government engagements.</p>
          <p>We understand RFP structures, ministry-level approval cycles, GeM procurement, and the compliance requirements that government technology demands. We don&rsquo;t just deliver code &mdash; we deliver systems that are VAPT-cleared, GIGW-compliant, accessibility-tested, and SLA-backed from day one.</p>
          <p>From Parliament of India to the Ministry of Tribal Affairs, our reference clients represent some of the most demanding, security-sensitive deployment environments in India.</p>
        </div>
      </div>

      <div class="stats-v2">
        <div><span class="num">10<span class="plus">+</span></span><span class="lbl">Years of Serving</span></div>
        <div><span class="num">500<span class="plus">+</span></span><span class="lbl">Projects Delivered</span></div>
        <div><span class="num">10<span class="plus">+</span></span><span class="lbl">Ministries Served</span></div>
        <div><span class="num">80<span class="plus">+</span></span><span class="lbl">Professionals</span></div>
      </div>
    </div>
    <div class="story-bg-decor" aria-hidden="true"></div>
  </section>

  <!-- How We Work Within Government Processes -->
  <section class="sect" style="background:#f9fafb;">
    <div class="container">
      <div class="sect-head">
        <span class="eyebrow" style="display:inline-block; margin-bottom:8px; color:var(--primary); font-family:var(--font-heading); font-weight:700; letter-spacing:0.18em; text-transform:uppercase; font-size:11px;">Our Delivery Model</span>
        <h2>How We Work Within Government Processes</h2>
      </div>

      <div class="proc-grid">
        <article class="proc-card">
          <div class="proc-card-ic" aria-hidden="true">
            <i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/linear/message-question.svg');"></i>
          </div>
          <h3>Pre-Bid Consultation</h3>
          <p>Technical advisory before RFP publication &mdash; at no cost to the department.</p>
        </article>
        <article class="proc-card">
          <div class="proc-card-ic" aria-hidden="true">
            <i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/linear/document-text.svg');"></i>
          </div>
          <h3>RFP / Tender Response</h3>
          <p>Comprehensive bids aligned with GFR norms and GeM standards.</p>
        </article>
        <article class="proc-card">
          <div class="proc-card-ic" aria-hidden="true">
            <i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/linear/lamp-on.svg');"></i>
          </div>
          <h3>Proof of Concept</h3>
          <p>Working PoC delivered within agreed timelines where required.</p>
        </article>
        <article class="proc-card">
          <div class="proc-card-ic" aria-hidden="true">
            <i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/linear/refresh-2.svg');"></i>
          </div>
          <h3>Agile Delivery</h3>
          <p>Sprint-based execution with weekly demos and transparent dashboards.</p>
        </article>
        <article class="proc-card">
          <div class="proc-card-ic" aria-hidden="true">
            <i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/linear/shield-tick.svg');"></i>
          </div>
          <h3>Security &amp; Compliance</h3>
          <p>VAPT, STQC-aligned testing and accessibility audit pre go-live.</p>
        </article>
        <article class="proc-card">
          <div class="proc-card-ic" aria-hidden="true">
            <i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/linear/send-2.svg');"></i>
          </div>
          <h3>Deployment &amp; Go-Live</h3>
          <p>Phased rollout with dedicated government liaison and on-site support.</p>
        </article>
        <article class="proc-card">
          <div class="proc-card-ic" aria-hidden="true">
            <i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/linear/headphone.svg');"></i>
          </div>
          <h3>AMC &amp; Ongoing Support</h3>
          <p>Annual Maintenance Contracts with SLA-backed helpdesk support.</p>
        </article>
        <article class="proc-card">
          <div class="proc-card-ic" aria-hidden="true">
            <i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/linear/people.svg');"></i>
          </div>
          <h3>Long-Term Partnership</h3>
          <p>Version upgrades, capacity expansion and continued advisory.</p>
        </article>
      </div>
    </div>
  </section>

