@{
    var ogRaw = ViewData["OgImage"]?.ToString() ?? "/images/trusted-by-government.webp";
    var ogUrl = ogRaw.StartsWith("/") ? $"https://gov.webority.in{ogRaw}" : ogRaw;
    var canonical = ViewData["CanonicalUrl"]?.ToString() ?? $"https://gov.webority.in{Context.Request.Path}";
    var activeNav = ViewData["ActiveNav"]?.ToString();
    var hostEnv = Context.RequestServices.GetService(typeof(Microsoft.AspNetCore.Hosting.IWebHostEnvironment)) as Microsoft.AspNetCore.Hosting.IWebHostEnvironment;
    var assetV = hostEnv?.EnvironmentName == "Development"
    ? System.DateTime.UtcNow.Ticks.ToString()
    : (System.Reflection.Assembly.GetEntryAssembly()?.GetName().Version?.ToString() ?? "1");
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Webority for Government</title>
    
    @* noindex in Dev/Staging always; in Prod only when the page sets ViewData["NoIndex"] *@
    <environment include="Development,Staging">
        <meta name="robots" content="noindex, nofollow" />
    </environment>
    @if (ViewData["NoIndex"] != null && (bool)ViewData["NoIndex"])
    {
        <environment include="Production">
            <meta name="robots" content="noindex, nofollow" />
        </environment>
    }
    
    <meta name="description" content="@(ViewData["Description"] ?? "Webority delivers secure, scalable digital solutions for government and public sector in India — e-governance platforms, citizen apps, AI, cybersecurity and compliance-ready software.")" />
    <meta name="keywords" content="@(ViewData["Keywords"] ?? "government software india, e-governance, gov tech, citizen services platform, public sector software, digital india")" />
    <meta name="author" content="Webority Technologies" />
    
    <meta property="og:title" content="@ViewData["Title"] | Webority for Government" />
    <meta property="og:description" content="@(ViewData["Description"] ?? "Secure, scalable software for government and public sector in India.")" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@($"https://gov.webority.in{Context.Request.Path}")" />
    <meta property="og:image" content="@ogUrl" />
    <meta property="og:site_name" content="Webority for Government" />
    <meta property="og:locale" content="en_IN" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@ViewData["Title"] | Webority for Government" />
    <meta name="twitter:description" content="@(ViewData["Description"] ?? "Secure, scalable software for government and public sector in India.")" />
    <meta name="twitter:image" content="@ogUrl" />
    
    <link rel="canonical" href="@canonical" />
    
