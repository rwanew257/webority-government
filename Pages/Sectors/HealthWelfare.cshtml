@page
@model Webority.Web.GovIndia.Pages.Sectors.HealthWelfareModel
@{
    ViewData["Title"] = "Health & Welfare — Digital Health Infrastructure";
    ViewData["Description"] = "Digital health infrastructure for government hospitals, tribal health programmes and medical records — DPDP Act 2023 compliant, offline-first for zero-connectivity field conditions.";
    ViewData["ActiveNav"] = "sectors";
    ViewData["BodyClass"] = "sectors-page sector-detail-page";
}
<section class="svc-hero">
    <div class="container">
      <div class="svc-hero-content">
        <nav class="sector-detail-crumbs" aria-label="Breadcrumb">
          <a asp-page="/Sectors">Sectors</a> <span aria-hidden="true">&rsaquo;</span> <span>Health &amp; Welfare</span>
        </nav>
        <span class="sector-detail-eyebrow">Government &amp; Public Sector</span>
        <h1>Health &amp; Welfare Infrastructure</h1>
        <p>Digital health infrastructure for government hospitals, tribal health programmes, and medical records management &mdash; built for DPDP Act 2023 compliance with offline-first capabilities for zero-connectivity field conditions.</p>
      </div>
    </div>
  </section>

  <section class="sect sect-soft">
    <div class="container">
      <div class="cap-grid">
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 4h12l5 5v17a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/>
              <path d="M19 4v5h5"/>
              <path d="M14 14v8M10 18h8"/>
            </svg>
          </div>
          <h3>Digital Health Records</h3>
          <p>DPDP Act 2023 compliant EHR systems with end-to-end encryption for patient data sovereignty.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="3" width="14" height="26" rx="2"/>
              <path d="M13 7h6M16 25h0.01"/>
              <path d="M23 8l7 7M30 8l-7 7"/>
            </svg>
          </div>
          <h3>Offline-First Mobile Apps</h3>
          <p>Field apps designed for zero-connectivity tribal areas with automated sync protocols.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 26V8a2 2 0 0 1 2-2h13a2 2 0 0 1 2 2v10"/>
              <path d="M8 19l4-4 4 4 4-6"/>
              <circle cx="23" cy="22" r="5"/>
              <path d="M27 26l3 3"/>
            </svg>
          </div>
          <h3>Disease Surveillance</h3>
          <p>Real-time epidemiological tracking with predictive outbreak modelling and alert systems.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 4l6 6"/>
              <path d="M25 7L8 24l-3 4 4-3L26 8z"/>
              <path d="M12 18l3 3"/>
            </svg>
          </div>
          <h3>Immunisation Tracking</h3>
          <p>Beneficiary-level vaccination status monitoring integrated with CoWIN and state health systems.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 4h8"/>
              <path d="M14 4v9L7 24a3 3 0 0 0 3 4h12a3 3 0 0 0 3-4l-7-11V4"/>
              <circle cx="13" cy="22" r="0.9" fill="currentColor"/>
              <circle cx="18" cy="20" r="0.9" fill="currentColor"/>
              <circle cx="16" cy="25" r="0.9" fill="currentColor"/>
            </svg>
          </div>
          <h3>Laboratory Information Systems</h3>
          <p>Sample tracking, test result management, and quality control for govt diagnostic labs.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="8" width="18" height="14" rx="2"/>
              <path d="M21 13l8-4v12l-8-4z"/>
              <circle cx="12" cy="15" r="3"/>
            </svg>
          </div>
          <h3>Telemedicine Platforms</h3>
          <p>Secure video consultation infrastructure connecting rural health workers to specialist doctors.</p>
        </article>
      </div>

      <div class="ref-project ref-project--inline ref-project--v2 ref-project--sickle">
        <div class="ref-project-content">
          <div class="ref-project-brand">
            <img class="ref-project-brand-logo" src="/images/logos/gov/Sickal Scan Logo.svg" alt="Sickle Scan mobile screening app" loading="lazy" />
          </div>
          <span class="ref-project-eyebrow">Showcasing Impact</span>
          <h3>Sickle Scan</h3>
          <p>Mobile haemoglobin screening app for tribal health workers conducting sickle cell anemia surveys in zero-connectivity field conditions &mdash; built for the Ministry of Tribal Affairs.</p>
          <a class="ref-project-cta" asp-page="/CaseStudies">View Case Study</a>
        </div>
        <div class="ref-project-visual" aria-hidden="true"></div>
      </div>

      <div class="sect-head sect-head--centered" style="margin-top:100px; margin-bottom:0;">
        <h2 style="font-family:var(--font-body); font-style:italic; font-weight:400; font-size:clamp(1.6rem, 2.6vw, 2.1rem); color:var(--heading); margin:0; text-align:center;">Global Partners &amp; References</h2>
      </div>
      <div class="partners-grid">
        <div class="partner-card">
          <div class="partner-card-logo">Ministry of Tribal Affairs</div>
          <div class="partner-card-name">Ministry of Tribal Affairs</div>
        </div>
        <div class="partner-card">
          <div class="partner-card-logo">
            <img src="/images/logos/gov/Safdarjan Logo 64px.svg" alt="Safdarjung Hospital logo" loading="lazy" />
          </div>
          <div class="partner-card-name">Safdarjung Hospital</div>
        </div>
        <div class="partner-card">
          <div class="partner-card-logo">
            <img src="/images/logos/gov/biomedomics.svg" alt="BioMedomics logo" loading="lazy" style="height:64px;width:auto;max-width:none;max-height:none;" />
          </div>
          <div class="partner-card-name">BioMedomics Inc.</div>
        </div>
      </div>

      <div class="sector-detail-back">
        <a asp-page="/Sectors" class="btn btn-outline btn-md">&larr; All Sectors</a>
        <a asp-page="/Contact" class="btn btn-primary btn-md">Discuss Your Requirements</a>
      </div>
    </div>
  </section>
