@page
@model Webority.Web.GovIndia.Pages.Sectors.ParliamentModel
@{
    ViewData["Title"] = "Parliament & Legislature — Governance Infrastructure";
    ViewData["Description"] = "Secure communication and collaboration infrastructure for India's parliamentary institutions — video-conferencing with enterprise-grade authentication and concurrent user management.";
    ViewData["ActiveNav"] = "sectors";
    ViewData["BodyClass"] = "sectors-page sector-detail-page";
}
<section class="svc-hero">
    <div class="container">
      <div class="svc-hero-content">
        <nav class="sector-detail-crumbs" aria-label="Breadcrumb">
          <a asp-page="/Sectors">Sectors</a> <span aria-hidden="true">&rsaquo;</span> <span>Parliament &amp; Legislature</span>
        </nav>
        <span class="sector-detail-eyebrow">Government &amp; Public Sector</span>
        <h1>Parliament &amp; Legislative Governance</h1>
        <p>Secure communication and collaboration infrastructure for India&rsquo;s parliamentary institutions &mdash; video-conferencing systems with enterprise-grade authentication and concurrent user management.</p>
      </div>
    </div>
  </section>

  <section class="sect sect-soft">
    <div class="container">
      <div class="cap-grid">
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 28h24"/>
              <path d="M6 28V14M11 28V14M16 28V14M21 28V14M26 28V14"/>
              <path d="M3 14h26"/>
              <path d="M16 4L4 11h24z"/>
            </svg>
          </div>
          <h3>Legislative Workflow</h3>
          <p>Question tracking, bill management, and parliamentary session coordination systems.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 8h8l3 3h13a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V10a2 2 0 0 1 2-2z"/>
              <path d="M11 19h12M11 23h8"/>
            </svg>
          </div>
          <h3>Document Management</h3>
          <p>Secure archival and retrieval of constitutional documents with version control.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5" y="14" width="22" height="14" rx="1"/>
              <path d="M11 14l5-10 5 10"/>
              <path d="M9 20l2.5 2.5L17 17"/>
            </svg>
          </div>
          <h3>Voting &amp; Attendance</h3>
          <p>Electronic voting systems and member attendance tracking with audit trails.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="6" y="5" width="20" height="22" rx="2"/>
              <path d="M10 5v22"/>
              <path d="M14 11h8M14 16h6M14 21h7"/>
              <circle cx="10" cy="11" r="1.2" fill="currentColor"/>
              <circle cx="10" cy="16" r="1.2" fill="currentColor"/>
              <circle cx="10" cy="21" r="1.2" fill="currentColor"/>
            </svg>
          </div>
          <h3>Committee Management</h3>
          <p>Scheduling, minutes recording, and report generation for parliamentary committees.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 13v6l16 6V7z"/>
              <path d="M20 12c2.2 0 4 1.8 4 4s-1.8 4-4 4"/>
              <path d="M9 19v6h4l-2-6"/>
            </svg>
          </div>
          <h3>Constituent Communication</h3>
          <p>Member portals for managing constituency queries and feedback.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 27h24"/>
              <rect x="8" y="15" width="3.5" height="12"/>
              <rect x="14" y="11" width="3.5" height="16"/>
              <rect x="20" y="19" width="3.5" height="8"/>
              <path d="M8 7l6 4 6-6 6 4"/>
            </svg>
          </div>
          <h3>Legislative Analytics</h3>
          <p>Data-driven insights on bill progression, member participation, and session productivity.</p>
        </article>
      </div>

      <div class="ref-project ref-project--inline ref-project--v2 ref-project--parliament">
        <div class="ref-project-content">
          <div class="ref-project-brand">
            <img class="ref-project-brand-logo" src="/images/logos/gov/parliament-cafeteria.svg" alt="Parliament of India — Sansad Cafeteria" loading="lazy" />
          </div>
          <span class="ref-project-eyebrow">Showcasing Impact</span>
          <h3>Video Conferencing Infrastructure for Parliament of India</h3>
          <p>200+ room video-conferencing portal with Single Sign-On authentication, supporting 20,000+ concurrent users for parliamentary proceedings.</p>
          <a class="ref-project-cta" asp-page="/CaseStudies">View Case Study</a>
        </div>
        <div class="ref-project-visual" aria-hidden="true"></div>
      </div>

      <div class="sect-head sect-head--centered" style="margin-top:100px; margin-bottom:0;">
        <h2 style="font-family:var(--font-body); font-style:italic; font-weight:400; font-size:clamp(1.6rem, 2.6vw, 2.1rem); color:var(--heading); margin:0; text-align:center;">Global Partners &amp; References</h2>
      </div>
      <div class="partners-grid">
        <div class="partner-card partner-card--wide-logo">
          <div class="partner-card-logo">
            <img src="/images/logos/gov/parliament-cafeteria.png" alt="Parliament of India logo" loading="lazy" />
          </div>
          <div class="partner-card-name">Parliament of India</div>
        </div>
        <div class="partner-card">
          <div class="partner-card-logo">Lok Sabha</div>
          <div class="partner-card-name">Lok Sabha Secretariat</div>
        </div>
        <div class="partner-card">
          <div class="partner-card-logo">Rajya Sabha</div>
          <div class="partner-card-name">Rajya Sabha Secretariat</div>
        </div>
      </div>

      <div class="sector-detail-back">
        <a asp-page="/Sectors" class="btn btn-outline btn-md">&larr; All Sectors</a>
        <a asp-page="/Contact" class="btn btn-primary btn-md">Discuss Your Requirements</a>
      </div>
    </div>
  </section>
