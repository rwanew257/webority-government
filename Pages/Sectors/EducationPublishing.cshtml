@page
@model Webority.Web.GovIndia.Pages.Sectors.EducationPublishingModel
@{
    ViewData["Title"] = "Education & Publishing — Knowledge Platforms";
    ViewData["Description"] = "Digital library platforms, e-book distribution and publishing workflow automation for India's national education and media organisations.";
    ViewData["ActiveNav"] = "sectors";
    ViewData["BodyClass"] = "sectors-page sector-detail-page";
}
<section class="svc-hero">
    <div class="container">
      <div class="svc-hero-content">
        <nav class="sector-detail-crumbs" aria-label="Breadcrumb">
          <a asp-page="/Sectors">Sectors</a> <span aria-hidden="true">&rsaquo;</span> <span>Education &amp; Publishing</span>
        </nav>
        <span class="sector-detail-eyebrow">Government &amp; Public Sector</span>
        <h1>Education &amp; Publishing Knowledge</h1>
        <p>Digital library platforms, e-book distribution, and publishing workflow automation for India&rsquo;s national education and media organisations.</p>
      </div>
    </div>
  </section>

  <section class="sect sect-soft">
    <div class="container">
      <div class="cap-grid">
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="5" width="3.5" height="22"/>
              <rect x="10" y="8" width="3.5" height="19"/>
              <rect x="16" y="4" width="3.5" height="23"/>
              <path d="M22 7l5 1-3 18-5-1z"/>
            </svg>
          </div>
          <h3>Digital Library Systems</h3>
          <p>E-book cataloguing, discovery, and distribution platforms with DRM and access control.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="7" y="3" width="18" height="26" rx="2"/>
              <path d="M11 8h10M11 13h10M11 18h8M16 25h0.01"/>
            </svg>
          </div>
          <h3>E-Reader Applications</h3>
          <p>Multi-format reading apps supporting EPUB, PDF, and Mobi with offline capabilities.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 6h13v22H5z"/>
              <path d="M9 13h6M9 18h4"/>
              <path d="M21 9l5 5-12 12-5 1 1-5z"/>
            </svg>
          </div>
          <h3>Publishing Workflow</h3>
          <p>Manuscript management, editorial coordination, and production tracking systems.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 4h16v24l-8-5-8 5z"/>
              <rect x="13" y="12" width="6" height="6" rx="1"/>
              <path d="M14 12v-2a2 2 0 0 1 4 0v2"/>
            </svg>
          </div>
          <h3>Rights Management</h3>
          <p>Copyright tracking, licensing, and royalty calculation automation.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="16" cy="16" r="11"/>
              <path d="M5 16h22"/>
              <path d="M16 5c3.2 3.5 4.5 7 4.5 11s-1.3 7.5-4.5 11"/>
              <path d="M16 5c-3.2 3.5-4.5 7-4.5 11s1.3 7.5 4.5 11"/>
            </svg>
          </div>
          <h3>Multi-Lingual Support</h3>
          <p>Content delivery in 22+ Indian languages with Unicode compliance.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 25h24"/>
              <path d="M4 5v20"/>
              <path d="M6 19l5-5 5 3 5-9 5 4"/>
              <circle cx="11" cy="14" r="1.3" fill="currentColor"/>
              <circle cx="21" cy="8" r="1.3" fill="currentColor"/>
            </svg>
          </div>
          <h3>Usage Analytics</h3>
          <p>Reading patterns, distribution metrics, and reader engagement insights.</p>
        </article>
      </div>

      <div class="ref-project ref-project--inline ref-project--v2 ref-project--nbt">
        <div class="ref-project-content">
          <div class="ref-project-brand">
            <img class="ref-project-brand-logo" src="/images/logos/gov/Nbt 120px logo.svg" alt="National Book Trust e-commerce platform" loading="lazy" />
          </div>
          <span class="ref-project-eyebrow">Showcasing Impact</span>
          <h3>NBT E-Commerce Platform</h3>
          <p>Digital storefront and rights-managed e-book distribution for the National Book Trust &mdash; multi-lingual catalogue across 22 Indian languages with secure payment workflows.</p>
          <a class="ref-project-cta" asp-page="/CaseStudies">View Case Study</a>
        </div>
        <div class="ref-project-visual" aria-hidden="true"></div>
      </div>

      <div class="sect-head sect-head--centered" style="margin-top:100px; margin-bottom:0;">
        <h2 style="font-family:var(--font-body); font-style:italic; font-weight:400; font-size:clamp(1.6rem, 2.6vw, 2.1rem); color:var(--heading); margin:0; text-align:center;">Global Partners &amp; References</h2>
      </div>
      <div class="partners-grid">
        <div class="partner-card">
          <div class="partner-card-logo">
            <img src="/images/logos/gov/nbt-india.png" alt="National Book Trust logo" loading="lazy" />
          </div>
          <div class="partner-card-name">National Book Trust</div>
        </div>
        <div class="partner-card">
          <div class="partner-card-logo">NCERT</div>
          <div class="partner-card-name">NCERT</div>
        </div>
        <div class="partner-card">
          <div class="partner-card-logo">UGC</div>
          <div class="partner-card-name">University Grants Commission</div>
        </div>
      </div>

      <div class="sector-detail-back">
        <a asp-page="/Sectors" class="btn btn-outline btn-md">&larr; All Sectors</a>
        <a asp-page="/Contact" class="btn btn-primary btn-md">Discuss Your Requirements</a>
      </div>
    </div>
  </section>
