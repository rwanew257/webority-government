@page
@model Webority.Web.GovIndia.Pages.Sectors.QualityStandardsModel
@{
    ViewData["Title"] = "Quality & Standards — Certification Systems";
    ViewData["Description"] = "Certification, accreditation and quality-compliance systems for India's regulatory and standards bodies — ISO-aligned digital frameworks.";
    ViewData["ActiveNav"] = "sectors";
    ViewData["BodyClass"] = "sectors-page sector-detail-page";
}
<section class="svc-hero">
    <div class="container">
      <div class="svc-hero-content">
        <nav class="sector-detail-crumbs" aria-label="Breadcrumb">
          <a asp-page="/Sectors">Sectors</a> <span aria-hidden="true">&rsaquo;</span> <span>Quality &amp; Standards</span>
        </nav>
        <span class="sector-detail-eyebrow">Government &amp; Public Sector</span>
        <h1>Quality &amp; Standards Certification</h1>
        <p>Certification, accreditation, and quality-compliance systems for India&rsquo;s regulatory and standards bodies &mdash; ISO-aligned digital frameworks.</p>
      </div>
    </div>
  </section>

  <section class="sect sect-soft">
    <div class="container">
      <div class="cap-grid">
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 4l2.5 3 4-0.5 0.5 4 3.5 2-1.5 3.5 1.5 3.5-3.5 2-0.5 4-4-0.5L16 28l-2.5-3-4 0.5-0.5-4-3.5-2 1.5-3.5L5.5 12.5l3.5-2 0.5-4 4 0.5z"/>
              <path d="M11 16l3 3 6-7"/>
            </svg>
          </div>
          <h3>Accreditation Management</h3>
          <p>Laboratory and certification-body accreditation lifecycle tracking and renewal systems.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5" y="6" width="22" height="22" rx="2"/>
              <path d="M5 12h22M11 4v6M21 4v6"/>
              <path d="M10 20l3 3 7-7"/>
            </svg>
          </div>
          <h3>Audit Scheduling</h3>
          <p>Automated audit planning, assessor assignment, and execution tracking platforms.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="6" width="24" height="20" rx="2"/>
              <path d="M9 19l5-5 4 4 5-8"/>
              <circle cx="14" cy="14" r="0.9" fill="currentColor"/>
              <circle cx="18" cy="18" r="0.9" fill="currentColor"/>
              <circle cx="23" cy="10" r="0.9" fill="currentColor"/>
            </svg>
          </div>
          <h3>Compliance Dashboards</h3>
          <p>Real-time monitoring of quality metrics and regulatory adherence across stakeholders.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 5h16a3 3 0 0 1 3 3v18a3 3 0 0 0-3-3H6z"/>
              <path d="M6 5v18"/>
              <path d="M13 9v9l2-2 2 2V9z"/>
            </svg>
          </div>
          <h3>Standards Repository</h3>
          <p>Digital library of national and international standards with search and reference tools.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5" y="6" width="22" height="16" rx="2"/>
              <path d="M10 22v6l3-2 3 2v-6"/>
              <path d="M9 12h10M9 16h7"/>
              <circle cx="22" cy="14" r="2.2"/>
            </svg>
          </div>
          <h3>Certification Lifecycle</h3>
          <p>End-to-end tracking from application submission to certificate issuance and renewal.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 4h12l5 5v17a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/>
              <path d="M19 4v5h5"/>
              <path d="M11 19v4M15 15v8M19 17v6"/>
            </svg>
          </div>
          <h3>Report Generation</h3>
          <p>Automated audit-report creation with templates and regulatory compliance checks.</p>
        </article>
      </div>

      <div class="ref-project ref-project--inline ref-project--v2 ref-project--samar">
        <div class="ref-project-content">
          <div class="ref-project-brand">
            <img class="ref-project-brand-logo" src="/images/logos/gov/Case Study Detail logo QCI .svg" alt="Quality Council of India" loading="lazy" style="width:72px; height:72px;" />
          </div>
          <span class="ref-project-eyebrow" style="color:#034EB4;">Showcasing Impact</span>
          <h3>Quality Management System for Bureau of Indian Standards</h3>
          <p>ISO certification tracking and compliance monitoring platform for 10,000+ enterprises &mdash; accreditation lifecycle, audit scheduling, and standards-repository search across the regulatory stack.</p>
          <a class="ref-project-cta" asp-page="/CaseStudies">View Case Study</a>
        </div>
        <div class="ref-project-visual" aria-hidden="true"></div>
      </div>

      <div class="sect-head sect-head--centered" style="margin-top:100px; margin-bottom:0;">
        <h2 style="font-family:var(--font-body); font-style:italic; font-weight:400; font-size:clamp(1.6rem, 2.6vw, 2.1rem); color:var(--heading); margin:0; text-align:center;">Global Partners &amp; References</h2>
      </div>
      <div class="partners-grid">
        <div class="partner-card">
          <div class="partner-card-logo">
            <img src="/images/logos/gov/qci.png" alt="Quality Council of India logo" loading="lazy" />
          </div>
          <div class="partner-card-name">Quality Council of India</div>
        </div>
        <div class="partner-card">
          <div class="partner-card-logo">NABL</div>
          <div class="partner-card-name">National Accreditation Board</div>
        </div>
        <div class="partner-card">
          <div class="partner-card-logo">BIS</div>
          <div class="partner-card-name">Bureau of Indian Standards</div>
        </div>
      </div>

      <div class="sector-detail-back">
        <a asp-page="/Sectors" class="btn btn-outline btn-md">&larr; All Sectors</a>
        <a asp-page="/Contact" class="btn btn-primary btn-md">Discuss Your Requirements</a>
      </div>
    </div>
  </section>
