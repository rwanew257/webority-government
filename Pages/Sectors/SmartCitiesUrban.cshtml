@page
@model Webority.Web.GovIndia.Pages.Sectors.SmartCitiesUrbanModel
@{
    ViewData["Title"] = "Smart Cities, Urban & NGOs — Municipal Platforms";
    ViewData["Description"] = "Smart-city platforms, urban-governance systems and technology for mission-driven organisations — designed for India's municipal and development sector.";
    ViewData["ActiveNav"] = "sectors";
    ViewData["BodyClass"] = "sectors-page sector-detail-page";
}
<section class="svc-hero">
    <div class="container">
      <div class="svc-hero-content">
        <nav class="sector-detail-crumbs" aria-label="Breadcrumb">
          <a asp-page="/Sectors">Sectors</a> <span aria-hidden="true">&rsaquo;</span> <span>Smart Cities, Urban &amp; NGOs</span>
        </nav>
        <span class="sector-detail-eyebrow">Government &amp; Public Sector</span>
        <h1>Smart Cities, Urban &amp; NGO Solutions</h1>
        <p>Smart-city platforms, urban-governance systems, and technology for mission-driven organisations &mdash; designed for India&rsquo;s municipal and development sector.</p>
      </div>
    </div>
  </section>

  <section class="sect sect-soft">
    <div class="container">
      <div class="cap-grid">
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5" y="14" width="9" height="14"/>
              <rect x="17" y="6" width="10" height="22"/>
              <path d="M8 18h3M8 22h3M20 12h4M20 16h4M20 20h4"/>
              <path d="M3 5c2-2 5-2 7 0M5 8c1-1 2-1 3 0"/>
            </svg>
          </div>
          <h3>Smart City Command Centres</h3>
          <p>Integrated IoT dashboards for traffic, waste, energy, and water management.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 15L15 7l10 8v12a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1z"/>
              <circle cx="22" cy="22" r="4.5"/>
              <path d="M22 19v6M20 22h4"/>
            </svg>
          </div>
          <h3>Property Tax Systems</h3>
          <p>GIS-based tax assessment, collection, and reconciliation for municipal corporations.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 6h20v16H14l-6 6v-6H6z"/>
              <path d="M11 14l3 3 6-6"/>
            </svg>
          </div>
          <h3>Citizen Grievance Portals</h3>
          <p>311-style complaint management with SLA tracking and resolution workflows.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="14" height="11"/>
              <path d="M17 14h6l3 4v4h-9"/>
              <circle cx="8" cy="25" r="2"/>
              <circle cx="22" cy="25" r="2"/>
              <path d="M6 8h6M6 5h6"/>
            </svg>
          </div>
          <h3>Waste Management</h3>
          <p>Route optimisation, vehicle tracking, and collection scheduling for solid-waste services.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 22h10v3a2 2 0 0 1-2 2h-6a2 2 0 0 1-2-2z"/>
              <path d="M11 22c-3-2-5-5-5-8a10 10 0 0 1 20 0c0 3-2 6-5 8"/>
              <path d="M13 26h6"/>
            </svg>
          </div>
          <h3>Energy Management</h3>
          <p>Street-light monitoring, consumption analytics, and fault detection systems.</p>
        </article>
        <article class="cap-card">
          <div class="cap-card-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 17l5-5 4 3 4-3 4 3 4-3 5 5"/>
              <path d="M3 21l4 4M29 21l-4 4"/>
              <path d="M12 18l4 4 4-4"/>
            </svg>
          </div>
          <h3>NGO Programme Management</h3>
          <p>Beneficiary tracking, fund utilisation, and impact-measurement platforms.</p>
        </article>
      </div>

      <div class="ref-project ref-project--inline ref-project--v2 ref-project--vasudha">
        <div class="ref-project-content">
          <div class="ref-project-brand">
            <img class="ref-project-brand-logo" src="/images/logos/gov/Case Study Detail logoVasudha.svg" alt="Vasudha Foundation" loading="lazy" style="width:96px; height:96px;" />
          </div>
          <span class="ref-project-eyebrow" style="color:#085938;">Showcasing Impact</span>
          <h3>Environment &amp; Sustainability Platform</h3>
          <p>A centralised environmental-data platform with GIS visualisation &mdash; bringing air quality, forest cover, and programme data onto a single geographic layer for statewide monitoring and decision-making.</p>
          <a class="ref-project-cta" asp-page="/CaseStudies" style="display:none;">View Case Study</a>
        </div>
        <div class="ref-project-visual" aria-hidden="true"></div>
      </div>

      <div class="sect-head sect-head--centered" style="margin-top:100px; margin-bottom:0;">
        <h2 style="font-family:var(--font-body); font-style:italic; font-weight:400; font-size:clamp(1.6rem, 2.6vw, 2.1rem); color:var(--heading); margin:0; text-align:center;">Global Partners &amp; References</h2>
      </div>
      <div class="partners-grid">
        <div class="partner-card">
          <div class="partner-card-logo">MoHUA</div>
          <div class="partner-card-name">Ministry of Housing &amp; Urban Affairs</div>
        </div>
        <div class="partner-card">
          <div class="partner-card-logo">Smart Cities</div>
          <div class="partner-card-name">Smart Cities Mission</div>
        </div>
        <div class="partner-card">
          <div class="partner-card-logo">
            <img src="/images/logos/gov/vasudha-foundation.png" alt="Vasudha Foundation logo" loading="lazy" />
          </div>
          <div class="partner-card-name">Vasudha Foundation</div>
        </div>
      </div>

      <div class="sector-detail-back">
        <a asp-page="/Sectors" class="btn btn-outline btn-md">&larr; All Sectors</a>
        <a asp-page="/Contact" class="btn btn-primary btn-md">Discuss Your Requirements</a>
      </div>
    </div>
  </section>
