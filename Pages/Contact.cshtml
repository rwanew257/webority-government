@page
@model Webority.Web.GovIndia.Pages.ContactModel
@{
    ViewData["Title"] = "Contact";
    ViewData["Description"] = "Speak to Webority Government's public-sector team — for briefings, RFP responses, empanelment, or partnership discussions.";
    ViewData["BodyClass"] = "contact-page";
}
<section class="svc-hero">
    <div class="container">
      <div class="svc-hero-content">
        <h1>Let&rsquo;s Start the Conversation</h1>
        <p>Whether you&rsquo;re exploring a new initiative, preparing for an upcoming tender or need IT professionals for an ongoing project &mdash; our Government Practice team responds within one business day.</p>
      </div>
    </div>
  </section>

  <!-- Direct Contact + Send an Enquiry -->
  <section class="sect">
    <div class="container">
      <div class="contact-split">

        <!-- Direct Contact card -->
        <div class="direct-contact-card">
          <h2>Direct Contact</h2>
          <ul class="contact-items">
            <li class="contact-item">
              <span class="contact-item-ic" aria-hidden="true">
                <i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/bold/sms.svg');"></i>
              </span>
              <span>contact@@webority.com</span>
            </li>
            <li class="contact-item">
              <span class="contact-item-ic" aria-hidden="true">
                <i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/bold/call.svg');"></i>
              </span>
              <span>(+91) 959 900 6518</span>
            </li>
            <li class="contact-item">
              <span class="contact-item-ic" aria-hidden="true">
                <i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/bold/location.svg');"></i>
              </span>
              <span>Gurugram, India</span>
            </li>
            <li class="contact-item">
              <span class="contact-item-ic" aria-hidden="true">
                <i class="iconsax-ic" style="--ic-url:url('https://cdn.jsdelivr.net/gh/lusaxweb/iconsax@@master/docs/Iconsax/Svg/All/bold/clock.svg');"></i>
              </span>
              <span>Mon &ndash; Sat, 10 AM &ndash; 7 PM IST</span>
            </li>
          </ul>
        </div>

        <!-- Send an Enquiry card -->
        <div class="enquiry-card">
          <h2>Send an Enquiry</h2>
          <p class="enq-intro">Fill in the details below. The more context you share, the better we can prepare before getting back to you.</p>

          <form id="contactForm" class="enquiry-form" novalidate>
            <div class="field-line">
              <label for="name">Full Name *</label>
              <input id="name" name="name" type="text" autocomplete="name" placeholder=" " required />
            </div>

            <div class="field-line">
              <label for="organisation">Ministry / Department / Organisation *</label>
              <input id="organisation" name="organisation" type="text" placeholder=" " required />
            </div>

            <div class="row-2">
              <div class="field-line">
                <label for="email">Official Email ID*</label>
                <input id="email" name="email" type="email" autocomplete="email" placeholder=" " required />
              </div>
              <div class="field-line">
                <label for="phone">Phone Number*</label>
                <input id="phone" name="phone" type="tel" autocomplete="tel" placeholder=" " required />
              </div>
            </div>

            <div class="field-line">
              <label for="message">Project Brief / Requirements*</label>
              <textarea id="message" name="message" rows="3" placeholder=" " required></textarea>
            </div>

            <div class="submit-row">
              <button type="submit" class="btn btn-primary btn-glow btn-md"><span class="btn-glow-label">Submit Enquiry</span><svg class="btn-glow-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg></button>
              <p id="formStatus" role="status" style="margin:0; font-size:0.92rem;"></p>
              <p class="privacy-note">Information shared is used only to respond to your enquiry and is never shared with third parties.</p>
            </div>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- Download Company Profile CTA â€” sits as the closing block of the page content, just above the site footer -->
  <section class="download-cta">
    <div class="container">
      <h2>Download Company Profile</h2>
      <ul class="download-cta-checks">
        <li><span class="ck" aria-hidden="true">&#x2713;</span> Pre-Bid Advisory at No Cost</li>
        <li><span class="ck" aria-hidden="true">&#x2713;</span> CMMI Level 5</li>
        <li><span class="ck" aria-hidden="true">&#x2713;</span> Response Within One Business Day</li>
        <li><span class="ck" aria-hidden="true">&#x2713;</span> GeM Registered</li>
      </ul>
      <!-- TODO-WG: link to the actual company-profile PDF once finalised by leadership -->
      <a class="btn btn-primary btn-glow btn-md" href="#" id="downloadProfileBtn" aria-label="Download company profile PDF" aria-haspopup="dialog"><span class="btn-glow-label">Download Profile</span><svg class="btn-glow-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg></a>
    </div>
  </section>

  <!-- Download Profile modal -->
  <div class="profile-modal-overlay" id="profileModal" role="dialog" aria-modal="true" aria-labelledby="profileModalTitle" aria-hidden="true">
    <div class="profile-modal">
     <div class="profile-modal-inner">
      <button type="button" class="profile-modal-close" id="profileModalClose" aria-label="Close dialog">
        <img src="/images/logos/gov/charm_cross.svg" alt="" aria-hidden="true" />
      </button>

      <div class="profile-modal-left" aria-hidden="true">
        <div class="why-v3-visual profile-modal-visual" data-auto-rotate="3000">
          <img class="why-v3-img why-v3-img--a is-active" src="/images/logos/gov/Munition logo.png" alt="" loading="lazy" />
          <img class="why-v3-img why-v3-img--b" src="" alt="" aria-hidden="true" />
          <span class="why-v3-badge">Ministry of Defense</span>
          <div class="why-v3-dots" role="tablist" aria-label="Trusted clients">
            <button class="why-v3-dot" type="button" role="tab" aria-selected="false" aria-label="Slide 1" data-img="/images/logos/gov/Vasudha Fundation.png" data-label="Ministry of Climate Change"></button>
            <button class="why-v3-dot" type="button" role="tab" aria-selected="false" aria-label="Slide 2" data-img="/images/logos/gov/BEE logo image .png" data-label="Ministry of Power / Clasp NGO"></button>
            <button class="why-v3-dot is-active" type="button" role="tab" aria-selected="true" aria-label="Slide 3" data-img="/images/logos/gov/Munition logo.png" data-label="Ministry of Defense"></button>
            <button class="why-v3-dot" type="button" role="tab" aria-selected="false" aria-label="Slide 4" data-img="/images/logos/gov/Vasudha Fundation.png" data-label="Ministry of Climate Change"></button>
          </div>
        </div>
      </div>

      <div class="profile-modal-right" data-state="form">
        <div class="profile-modal-brand">
          <strong>WEBORITY</strong>
          <span>TECHNOLOGIES</span>
        </div>

        <div class="profile-modal-state profile-modal-state-form">
          <p class="profile-modal-lead" id="profileModalTitle">Enter your email to receive the Download Company Profile.</p>
          <form class="profile-modal-form" id="profileModalForm" novalidate>
            <div class="profile-modal-field">
              <label for="profileModalEmail">Email ID*</label>
              <input id="profileModalEmail" name="email" type="email" autocomplete="email" placeholder=" " required />
            </div>
            <button type="submit" class="profile-modal-submit btn btn-primary btn-glow"><span class="btn-glow-label">Submit</span><svg class="btn-glow-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg></button>
            <p class="profile-modal-note">We Promise not to spam you!</p>
          </form>
        </div>

        <div class="profile-modal-state profile-modal-state-thanks" hidden>
          <h3 class="profile-modal-thanks-title">Thank You!</h3>
          <p class="profile-modal-thanks-text">We&rsquo;ve sent the Company Profile to your inbox. Please check your email &mdash; it should arrive within a few minutes.</p>
          <p class="profile-modal-thanks-sub">If you don&rsquo;t see it, check your spam folder or write to <a href="mailto:contact@@webority.com">contact@@webority.com</a>.</p>
        </div>

        <p class="profile-modal-footer"><span class="profile-modal-footer-year">&copy;2026</span> <span class="profile-modal-footer-name">Webority Technologies Private Limited</span></p>
      </div>
     </div>
    </div>
  </div>
